    src_line = ", ".join(sources) if sources else "(none)"
    mail_note = (
        "Mail-chain sources (AW_/RE_) were used only as secondary evidence."
        if used_mail_docs else
        "Mail-chain sources (AW_/RE_) were not used for the answer."
    )

    q_red = redact_remove(question)
    pack_red = redact_remove(extraction_pack)

    return f"""
You are drafting a professional corporate email reply in procurement/sustainability context.

HARD RULES (must follow):
- Use ONLY the extracted points below. Do not invent facts.
- If the extracted points do not answer the question, ask 1–2 short clarifying questions instead of guessing.
- Output MUST be bilingual: German first, then a separator line '---', then English.
- Keep it human and complete: include all relevant points from the extracted list (do not drop points arbitrarily).
- Do NOT answer unrelated questions. Answer only what is asked.
- Include greeting + closing as specified.
- Do NOT include personal names, supplier names, emails, phone numbers, addresses, IDs, internal codes, or money amounts.
- At the end of EACH language section, add "Sources used:" with the allowed list only (titles+chunk ids).

STRUCTURE:
German:
Hallo {greeting_name},
(1–2 sentences context)
Then either short paragraphs or bullet points (use bullets if multiple points).
If the answer is long (>= 4 bullets or >= ~120 words), add a short "Kurzfassung:" with 2–4 bullets at the end of German.
If the answer is already short, skip the short summary.
Close:
Mit freundlichen Grüßen
{signature_name}

English:
Hello {greeting_name},
Same content in English.
If long, add "Short summary:" 2–4 bullets; else omit.
Close:
Best regards,
{signature_name}

Question:
{q_red}

Extracted grounded points:
{pack_red}

Allowed sources list:
{src_line}

Note:
{mail_note}
""".strip()

def call_llm(client: AzureOpenAI, prompt: str) -> str:
    # Azure chat.completions path (works with your Nexus deployment)
    resp = client.chat.completions.create(
        model=AZURE_DEPLOYMENT_NAME,
        temperature=LLM_TEMPERATURE,
        max_completion_tokens=LLM_MAX_COMPLETION_TOKENS,
        messages=[
            {"role": "system", "content": "Follow the hard rules exactly. Use only extracted points."},
            {"role": "user", "content": prompt},
        ],
    )
    return (resp.choices[0].message.content or "").strip()


