# NEVER-EMPTY FALLBACK
# =========================================================
def build_fallback_reply(greeting_name: str, signature_name: str, question: str, sources: List[str]) -> str:
    src_line = ", ".join(sources) if sources else "(none)"
    q = (question or "").strip()
    return (
        f"Hallo {greeting_name},\n"
        f"ich hoffe, es geht Ihnen gut.\n\n"
        f"Ich habe in den verfügbaren Dokumentenauszügen keine eindeutige, belastbare Antwort gefunden.\n"
        f"Können Sie bitte den Dokumentennamen/Abschnitt nennen oder kurz präzisieren, worauf Sie genau abzielen?\n\n"
        f"Frage (Kurzform): {q}\n\n"
        f"Mit freundlichen Grüßen\n"
        f"{signature_name}\n\n"
        f"Sources used: {src_line}\n\n"
        f"---\n\n"
        f"Hello {greeting_name},\n"
        f"I hope you are doing well.\n\n"
        f"I could not find a clear, well-supported answer in the available document excerpts.\n"
        f"Could you please point to the document/section or clarify the exact requirement you mean?\n\n"
        f"Question (short): {q}\n\n"
        f"Best regards,\n"
        f"{signature_name}\n\n"
        f"Sources used: {src_line}"
    )

def safe_nonempty(text: str) -> str:
    return (text or "").strip()


