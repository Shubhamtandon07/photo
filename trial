def md_bold_to_html(text: str) -> str:
    return re.sub(r"\*\*(.+?)\*\*", r"<b>\1</b>", text or "")

def format_outlook_html(text: str) -> str:
    text = (text or "").replace("\r\n", "\n").strip()
    if not text:
        return "<p></p>"

    blocks = re.split(r"\n\s*\n", text)
    out = []

    for block in blocks:
        raw_lines = [ln.rstrip() for ln in block.split("\n") if ln.strip()]
        if not raw_lines:
            continue

        if all(ln.lstrip().startswith("- ") for ln in raw_lines):
            out.append("<ul>")
            for ln in raw_lines:
                ln2 = ln.lstrip()[2:].strip()
                ln2 = escape(ln2).replace("&lt;b&gt;", "<b>").replace("&lt;/b&gt;", "</b>")
                out.append(f"<li>{ln2}</li>")
            out.append("</ul>")
        else:
            safe_lines = []
            for ln in raw_lines:
                ln2 = escape(ln.strip()).replace("&lt;b&gt;", "<b>").replace("&lt;/b&gt;", "</b>")
                safe_lines.append(ln2)
            out.append("<p>" + "<br>".join(safe_lines) + "</p>")

    return "\n".join(out)


