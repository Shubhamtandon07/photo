def clean_ws(s: str) -> str:
    return re.sub(r"\s+", " ", s or "").strip()

def strict_subject_ok(subject: str) -> bool:
    return (subject or "").strip().casefold() == STRICT_SUBJECT.casefold()

def clean_html_to_text(html: str) -> str:
    txt = re.sub(r"<[^>]+>", " ", html or "", flags=re.S)
    return clean_ws(txt)

def clean_question(q: str) -> str:
    try:
        import html as _html
        q = _html.unescape(q or "")
    except Exception:
        q = q or ""
    q = q.replace("\xa0", " ")
    q = re.sub(r"\s+", " ", q).strip()
    return q

def safe_firstname_from_email(email: str) -> str:
    email = (email or "").strip()
    local = email.split("@", 1)[0] if "@" in email else email
    first = local.split(".", 1)[0].strip()
    if not first:
        return "Colleague"
    return first[:1].upper() + first[1:]

def format_outlook_html(text: str) -> str:
    text = (text or "").replace("\r\n", "\n").strip()
    if not text:
        return "<p></p>"
    blocks = re.split(r"\n\s*\n", text)
    out = []
    for block in blocks:
        lines = [ln.rstrip() for ln in block.split("\n") if ln.strip()]
        if not lines:
            continue
        if all(ln.lstrip().startswith("- ") for ln in lines):
            out.append("<ul>")
            for ln in lines:
                ln2 = ln.lstrip()[2:].strip()
                out.append(f"<li>{escape(ln2)}</li>")
            out.append("</ul>")
        else:
            out.append("<p>" + "<br>".join(escape(ln.strip()) for ln in lines) + "</p>")
    return "\n".join(out)

def tokenize(s: str) -> List[str]:
    toks = re.split(r"[^a-zA-Z0-9ÄÖÜäöüß]+", (s or "").lower())
    return [t for t in toks if t and t not in STOPWORDS and len(t) >= 3]


# =========================
# REDACTION FOR LLM INPUT
# - Keep normal terms.
# - For MSG archives, we redact harder (names too), because those are full conversations.
# =========================
EMAIL_RE = re.compile(r"\b[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}\b", re.I)
PHONE_RE = re.compile(r"(?:(?:\+|00)\d{1,3}[\s\-]?)?(?:\(?\d{2,5}\)?[\s\-]?)?\d[\d\s\-]{6,}\d")
URL_RE = re.compile(r"\bhttps?://[^\s<>()]+\b", re.I)
IBAN_RE = re.compile(r"\b[A-Z]{2}\d{2}[A-Z0-9]{11,30}\b", re.I)
REF_RE = re.compile(r"\b(?:VU|SP|PR|PO|NCR|Ticket|Case|Req|Request|ID|Ref)\s*[:#]?\s*[A-Za-z0-9\-_/]*\d[A-Za-z0-9\-_/]*\b", re.I)

# Stronger name patterns (applied ONLY to msg archives)
TITLE_NAME_RE = re.compile(r"\b(?:Mr|Mrs|Ms|Miss|Dr|Prof|Herr|Frau)\.?\s+[A-ZÄÖÜ][a-zäöüß]+(?:\s+[A-ZÄÖÜ][a-zäöüß]+){0,2}\b")
FIRST_LAST_RE = re.compile(r"\b[A-ZÄÖÜ][a-zäöüß]{2,}\s+[A-ZÄÖÜ][a-zäöüß]{2,}\b")

HEADER_LINE_RE = re.compile(r"(?im)^\s*(von|from|an|to|cc|bcc|gesendet|sent|betreff|subject)\s*:\s*.*$", re.M)

def redact_for_llm_input_doc(s: str) -> str:
    """Light redaction for real KB docs."""
    if not s:
        return ""
    t = s
    t = EMAIL_RE.sub("[EMAIL]", t)
    t = PHONE_RE.sub("[PHONE]", t)
    t = URL_RE.sub("[URL]", t)
    t = IBAN_RE.sub("[IBAN]", t)
    t = REF_RE.sub("[REF]", t)
    t = re.sub(r"\s+", " ", t).strip()
    return t

def redact_for_llm_input_msg(s: str) -> str:
    """Stronger redaction for mail archives (.msg)."""
    if not s:
        return ""
    t = s
    t = HEADER_LINE_RE.sub("", t)
    t = EMAIL_RE.sub("[EMAIL]", t)
    t = PHONE_RE.sub("[PHONE]", t)
    t = URL_RE.sub("[URL]", t)
    t = IBAN_RE.sub("[IBAN]", t)
    t = REF_RE.sub("[REF]", t)
    t = TITLE_NAME_RE.sub("[PERSON]", t)
    t = FIRST_LAST_RE.sub("[PERSON]", t)
    # compress
    t = re.sub(r"\n{3,}", "\n\n", t)
    t = re.sub(r"[ \t]{2,}", " ", t)
    return t.strip()


