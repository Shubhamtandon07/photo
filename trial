STOPWORDS = set("""
the a an and or to of in on for with without from by at is are was were be been being
der die das und oder zu von im in am an auf für mit ohne aus bei ist sind war waren
""".split())

def clean_ws(s: str) -> str:
    return re.sub(r"\s+", " ", s or "").strip()

def strict_subject_ok(subject: str) -> bool:
    return (subject or "").strip().casefold() == STRICT_SUBJECT.casefold()

def clean_html_to_text(html: str) -> str:
    txt = re.sub(r"<[^>]+>", " ", html or "", flags=re.S)
    return clean_ws(txt)

def safe_firstname_from_email(email: str) -> str:
    email = (email or "").strip()
    local = email.split("@", 1)[0] if "@" in email else email
    first = local.split(".", 1)[0].strip()
    if not first:
        return "Colleague"
    return first[:1].upper() + first[1:]

def format_outlook_html(text: str) -> str:
    text = (text or "").replace("\r\n", "\n").strip()
    if not text:
        return "<p></p>"

    blocks = re.split(r"\n\s*\n", text)
    out = []
    for block in blocks:
        lines = [ln.rstrip() for ln in block.split("\n") if ln.strip()]
        if not lines:
            continue
        if all(ln.lstrip().startswith("- ") for ln in lines):
            out.append("<ul>")
            for ln in lines:
                ln2 = ln.lstrip()[2:].strip()
                out.append(f"<li>{escape(ln2)}</li>")
            out.append("</ul>")
        else:
            out.append("<p>" + "<br>".join(escape(ln.strip()) for ln in lines) + "</p>")
    return "\n".join(out)

def tokenize(s: str) -> List[str]:
    toks = re.split(r"[^a-zA-Z0-9ÄÖÜäöüß]+", (s or "").lower())
    return [t for t in toks if t and t not in STOPWORDS and len(t) >= 3]

def looks_like_table_noise(text: str) -> bool:
    if not text:
        return False
    pipe_ratio = text.count("|") / max(1, len(text))
    return pipe_ratio >= PIPE_HEAVY_THRESHOLD

def normalize_tableish_line(line: str) -> str:
    # collapse repeated pipes/spaces to reduce duplicates like:
    # "über ... | über ... | über ..."
    s = line
    s = re.sub(r"\s*\|\s*", " | ", s)
    s = re.sub(r"(?:\s\|\s)+", " | ", s)
    s = re.sub(r"\s{2,}", " ", s).strip()
    # if it's repeating same segment many times, compress
    parts = [p.strip() for p in s.split("|")]
    if len(parts) >= 4:
        # keep unique parts while preserving order
        seen = set()
        uniq = []
        for p in parts:
            k = p.lower()
            if k and k not in seen:
                seen.add(k)
                uniq.append(p)
        # if uniq got much shorter, use it
        if len(uniq) <= max(2, len(parts)//3):
            s = " | ".join(uniq)
    return s


