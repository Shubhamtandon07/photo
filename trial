def build_site_queries(domain: str, material: str, keywords: list[str]) -> list[str]:
    base = [
        "human rights violation",
        "forced labor",
        "child labor",
        "environmental damage",
        "pollution contamination",
        "lawsuit investigation",
        "supply chain",
        "mining extraction",
    ]
    kws = keywords[:6] if keywords else []
    queries = []

    # material + all broad combos
    queries.append(f"site:{domain} {material} mining")
    queries.append(f"site:{domain} {material} human rights")
    queries.append(f"site:{domain} {material} environmental")
    queries.append(f"site:{domain} {material} supply chain")

    # include some keyword variants
    for k in kws[:4]:
        queries.append(f"site:{domain} {material} {k}")

    # allow a fallback query without forced extra terms
    queries.append(f"site:{domain} {material}")

    # dedupe keep first QUERIES_PER_SITE
    uniq = []
    for q in queries:
        if q not in uniq:
            uniq.append(q)
    return uniq[:QUERIES_PER_SITE]

def build_fallback_queries(material: str, keywords: list[str]) -> list[str]:
    base = [
        f"{material} human rights violation",
        f"{material} forced labor allegations",
        f"{material} pollution contamination spill",
        f"{material} mining supply chain issues",
        f"{material} environmental lawsuit",
        f"{material} community displacement"
    ]
    for k in keywords[:6]:
        base.append(f"{material} {k}")

    uniq = []
    for q in base:
        if q not in uniq:
            uniq.append(q)
    return uniq


