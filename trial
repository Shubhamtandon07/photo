# ANSWER EXTRACTION (deterministic)
# =========================================================
def sentence_split(text: str) -> list[str]:
    txt = re.sub(r"\s+", " ", text or "").strip()
    if not txt:
        return []
    parts = re.split(r"(?<=[\.\!\?])\s+", txt)
    out = [p.strip(" -•\t\r\n") for p in parts if len(p.strip()) >= 15]
    return out

def build_bullets_from_chunks(chunks_scored: list[tuple[float, str, str]], query: str, focus_term: str | None, max_points: int = 5) -> list[str]:
    bullets = []
    used = set()

    anchors = []
    if focus_term:
        anchors.append(focus_term.lower())
    anchors += tokenize(query)[:8]
    anchors = [a for a in anchors if a]

    def anchored(s: str) -> bool:
        s_low = s.lower()
        return any(a in s_low for a in anchors) if anchors else True

    for score, filename, ch in chunks_scored:
        for sent in sentence_split(ch):
            if not anchored(sent):
                continue
            key = sent.lower()
            if key in used:
                continue
            used.add(key)
            bullets.append(sent)
            if len(bullets) >= max_points:
                break
        if len(bullets) >= max_points:
            break

    if not bullets and chunks_scored:
        for sent in sentence_split(chunks_scored[0][2])[:max_points]:
            bullets.append(sent)

    return bullets[:max_points]


