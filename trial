def load_kb_docs(kb_dir: str) -> List[Tuple[str, str, str, bool]]:
    base = Path(kb_dir)
    if not base.exists() or not base.is_dir():
        raise SystemExit(f"KB_DIR not found: {kb_dir}")

    files = [p for p in base.rglob("*") if p.is_file() and p.suffix.lower() in SUPPORTED_EXTS]
    files = files[:MAX_DOCS]

    docs = []
    for p in sorted(files):
        try:
            txt = extract_text_from_file(p)
            txt = (txt or "").strip()
            if not txt:
                continue
            txt = txt[:MAX_CHARS_PER_DOC]
            docs.append((str(p), p.name, txt, is_maily_filename(p)))
        except Exception:
            continue
    return docs


def doc_priority_adjustment(filename: str) -> float:
    fn = (filename or "").lower()
    score = 0.0
    if fn.startswith(MAILY_PREFIXES):
        score -= 0.80
    if any(h in fn for h in MAILY_HINTS):
        score -= 0.25
    if re.search(r"(?i)\b(mbn|din|iso|vda|standard|policy|guideline|kapitel|chapter|requirements|norm)\b", fn):
        score += 0.30
    return score


def rank_docs_simple(docs, query: str, include_maily: bool, top_k: int) -> List[Tuple[float, str, str, str, bool]]:
    q_toks = set(tokenize(query))
    scored = []
    for fullpath, fname, text, is_maily in docs:
        if (not include_maily) and is_maily:
            continue
        tl = text.lower()
        overlap = sum(1 for tk in q_toks if tk in tl)
        base = overlap / max(1, len(q_toks))
        score = float(base) + doc_priority_adjustment(fname)
        scored.append((score, fullpath, fname, text, is_maily))
    scored.sort(key=lambda x: x[0], reverse=True)
    return scored[:top_k]


# =========================
# REQUIREMENT-LINE EXTRACTION (coverage) — DOCS
# =========================
REQ_LINE_RE = re.compile(
    r"(?i)\b(must|shall|required|requirement|need to|has to|within\s+\d+\s*(days|weeks)|"
    r"muss|soll|verpflicht|erforder|anforder|ist\s+innerhalb|innerhalb\s+von|"
    r"gemäß|in\s+accordance|nachweis|beleg|offenlegung|disclose|submit|"
    r"CMRT|RMAP|SAQ|DDQ|SupplierAssurance|tier[-\s]*n|lieferkette|transparenz|"
    r"CO2|CO₂|Sekundärmaterial|Rezyklat|Grünstrom|renewable)\b"
)
SECTION_RE = re.compile(r"^\s*(\d+(\.\d+){0,3})\s+|^\s*(Kapitel|Chapter)\s+\d+", re.I)

def extract_requirement_lines(text: str) -> List[str]:
    if not text:
        return []
    raw = re.split(r"\n+|(?<=[\.\!\?])\s+", text)
    out = []
    for r in raw:
        s = clean_ws(r)
        if not s or len(s) < 18:
            continue
        s = re.sub(r"\s*\|\s*", " | ", s)
        s = re.sub(r"(\b\w+\b)( \| \1){2,}", r"\1", s, flags=re.I)
        if SECTION_RE.search(s) or REQ_LINE_RE.search(s):
            if len(s) > MAX_EVIDENCE_CHARS_PER_LINE:
                s = s[:MAX_EVIDENCE_CHARS_PER_LINE] + "…"
            out.append(s)
    # de-dup
    seen = set()
    uniq = []
    for s in out:
        k = s.lower()
        if k in seen:
            continue
        seen.add(k)
        uniq.append(s)
    return uniq


def build_requirement_pack(top_docs, question: str, max_lines: int) -> Tuple[List[Tuple[str, str, bool]], List[str]]:
    q_toks = set(tokenize(question))
    findings = []

    for score, fullpath, fname, text, is_maily in top_docs:
        lines = extract_requirement_lines(text)

        scored_lines = []
        for ln in lines:
            ltoks = set(tokenize(ln))
            overlap = len(q_toks & ltoks)
            anchor = 0
            if any(w in ln.lower() for w in ["umwelt", "environment", "co2", "co₂", "sekundär", "rezykl", "rezyklat", "grünstrom", "renewable"]):
                anchor += 3
            if any(w in ln.lower() for w in ["lieferkette", "tier", "transparenz", "saq", "ddq", "cmrt", "rmap"]):
                anchor += 2
            if REQ_LINE_RE.search(ln):
                anchor += 1
            scored_lines.append((overlap + anchor, ln))

        scored_lines.sort(key=lambda x: x[0], reverse=True)

        take = 70 if not is_maily else 18
        for s, ln in scored_lines[:take]:
            if s <= 0 and not REQ_LINE_RE.search(ln):
                continue
            findings.append((fname, ln, is_maily))

    # global cap
    seen = set()
    final = []
    for fname, ln, is_maily in findings:
        k = (fname.lower(), ln.lower())
        if k in seen:
            continue
        seen.add(k)
        final.append((fname, ln, is_maily))
        if len(final) >= max_lines:
            break

    # sources (exclude AW/RE)
    sources = []
    for fname, _, _ in final:
        if fname.lower().startswith(EXCLUDE_AS_SOURCES_PREFIXES):
            continue
        if fname not in sources:
            sources.append(fname)
    sources = sources[:8]

    return final, sources


def build_findings_text(findings: List[Tuple[str, str, bool]]) -> str:
    lines = []
    for i, (fname, ln, is_maily) in enumerate(findings, start=1):
        tag = "MAIL-CHAIN" if is_maily else "DOC"
        safe_ln = redact_for_llm_input_doc(ln)
        lines.append(f"[DOC-{i}] ({tag}) {fname}: {safe_ln}")
    return "\n".join(lines)


