def build_azure_client() -> AzureOpenAI:
    key = os.getenv("OPENAI_API_KEY", "").strip()
    if not key:
        raise SystemExit("OPENAI_API_KEY env var missing (GenAI-Nexus key). Set it in notebook/session.")
    return AzureOpenAI(
        api_key=key,
        azure_endpoint=AZURE_OPENAI_ENDPOINT,
        api_version=AZURE_API_VERSION,
    )

def build_llm_prompt_copilot_style(
    question: str,
    greeting_name: str,
    signature_name: str,
    extracted_points: List[Tuple[str, str]],
    sources_used: List[str],
    used_maily: bool
) -> str:
    q_red = redact_light(question)
    src_line = ", ".join(sources_used) if sources_used else "(none)"

    points_block = "\n".join([f"- {s} {cit}" for cit, s in extracted_points]) if extracted_points else "(none)"

    # Copilot-style structure template
    mail_note = "Secondary MAIL-CHAIN docs were used for style/identical Q&A only." if used_maily else "MAIL-CHAIN docs were not needed."

    return f"""
You are drafting a professional corporate email reply in procurement/sustainability context.

HARD RULES (strict):
- Use ONLY the extracted points below. Do not invent facts.
- If extracted points do not answer the question, ask 1–2 short clarifying questions instead of guessing.
- Answer ONLY what the user asked. Do not add adjacent topics.
- Include ALL relevant extracted points; do not arbitrarily output only 1–2 if there are more.
- Output MUST be bilingual: German first, then a separator line '---', then English.
- Do NOT include personal names, supplier names, email addresses, phone numbers, addresses, IDs, internal org codes, or money amounts.
- Keep citations exactly as given (e.g., [file.docx#p12]) and place them at the end of the sentence/point they support.
- At the end of EACH language section add: "Sources used: <doc titles only>" using the allowed list.

STRUCTURE (Copilot-like):
German:
- Start with greeting.
- Then a short intro sentence (1 line).
- Then numbered sections, each with bilingual header:
  "1. <English header> / <German header>"
  Under each section: 1–3 bullets max, each bullet ends with citation(s).
- Finish with: if the answer is long (>=4 bullets total OR >120 words), add:
  "Kurzfassung:" with 2–4 short bullets (NO new info).
- Close with signature.

English:
- Same structure and content, fully translated, and keep the same citations.
- If long, add "Short summary:" (2–4 bullets) else omit.

Question:
{q_red}

Extracted points (ground truth; use these only):
{points_block}

Allowed sources list for "Sources used":
{src_line}

Note:
{mail_note}
""".strip()

def call_llm(client: AzureOpenAI, prompt: str) -> str:
    resp = client.chat.completions.create(
        model=AZURE_DEPLOYMENT_NAME,
        temperature=LLM_TEMPERATURE,
        max_completion_tokens=LLM_MAX_COMPLETION_TOKENS,
        messages=[
            {"role": "system", "content": "Follow the hard rules exactly. Use only extracted points."},
            {"role": "user", "content": prompt},
        ],
    )
    return (resp.choices[0].message.content or "").strip()

