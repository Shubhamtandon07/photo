def load_msg_archives(msg_dirs: List[str]) -> List[Tuple[str, str, str, bool]]:
    """
    Returns docs-like tuples: (fullpath, filename, text, is_maily=True)
    These are always treated as mail examples, not authoritative standards.
    """
    extract_msg = _import_extract_msg()

    all_msgs: List[Path] = []
    for d in msg_dirs:
        base = Path(d)
        if base.exists() and base.is_dir():
            all_msgs.extend([p for p in base.rglob("*.msg") if p.is_file()])

    # stable order, cap
    all_msgs = sorted(all_msgs)[:MAX_MSG_FILES_TOTAL]

    out = []
    for p in all_msgs:
        try:
            m = extract_msg.Message(str(p))
            # some versions parse lazily
            subj = (getattr(m, "subject", "") or "").strip()
            body = (getattr(m, "body", "") or "").strip()
            htmlb = (getattr(m, "htmlBody", "") or "").strip()

            txt = body if body else ""
            if not txt and htmlb:
                txt = clean_html_to_text(htmlb)

            # stitch minimal structure
            combined = f"Subject: {subj}\n\n{txt}".strip()
            combined = combined[:MAX_CHARS_PER_MSG]

            if not combined:
                continue

            # strong redaction for msg archives
            combined = redact_for_llm_input_msg(combined)

            out.append((str(p), p.name, combined, True))
        except Exception:
            continue

    return out


