def strip_subject_lines(text: str) -> str:
    """
    Remove Subject/Betreff lines anywhere + normalize blank lines.
    Minimal post-clean to enforce your preference.
    """
    if not text:
        return ""
    t = re.sub(r"(?im)^\s*(subject|betreff)\s*:\s*.*\n+", "", text)
    t = re.sub(r"\n{3,}", "\n\n", t).strip()
    return t


# =========================
# GREETING ENFORCER (YOU ASKED)
# =========================
def ensure_greetings(text: str, greeting_name: str, english_first: bool) -> str:
    """
    If the model forgets greeting lines, add them (minimal).
    Does NOT change content besides adding missing greeting lines.
    """
    if not text:
        return text
    t = text.strip()

    # Split into two sections by exact delimiter line '---'
    parts = re.split(r"(?m)^\s*---\s*$", t)
    if len(parts) != 2:
        # If model didn't follow delimiter, do nothing here.
        return t

    first = parts[0].strip()
    second = parts[1].strip()

    def has_de_greeting(s: str) -> bool:
        return bool(re.search(r"(?im)^\s*hallo\b", s))

    def has_en_greeting(s: str) -> bool:
        return bool(re.search(r"(?im)^\s*hello\b", s))

    # Determine which section is DE/EN based on english_first flag
    if english_first:
        en_sec, de_sec = first, second
        if not has_en_greeting(en_sec):
            en_sec = f"Hello {greeting_name},\n" + en_sec
        if not has_de_greeting(de_sec):
            de_sec = f"Hallo {greeting_name},\n" + de_sec
        return en_sec.strip() + "\n\n---\n\n" + de_sec.strip()

    else:
        de_sec, en_sec = first, second
        if not has_de_greeting(de_sec):
            de_sec = f"Hallo {greeting_name},\n" + de_sec
        if not has_en_greeting(en_sec):
            en_sec = f"Hello {greeting_name},\n" + en_sec
        return de_sec.strip() + "\n\n---\n\n" + en_sec.strip()


