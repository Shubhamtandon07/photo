IMG_EXTS = {".png", ".jpg", ".jpeg", ".gif", ".bmp", ".tif", ".tiff", ".webp"}

def pick_relevant_image(question: str, image_dir: str) -> Optional[Path]:
    """
    Best-effort:
    - If filename contains any query token, prefer that.
    - Else return None.
    """
    base = Path(image_dir)
    if not base.exists() or not base.is_dir():
        return None

    imgs = [p for p in base.rglob("*") if p.is_file() and p.suffix.lower() in IMG_EXTS]
    if not imgs:
        return None

    q_toks = tokenize(question)
    if not q_toks:
        return None

    best = None
    best_score = 0
    for p in imgs:
        fn = p.name.lower()
        score = sum(1 for tk in set(q_toks) if tk in fn)
        if score > best_score:
            best_score = score
            best = p

    # require at least 2 hits to avoid random images
    if best and best_score >= 2:
        return best
    return None

def embed_inline_image(reply_item, image_path: Path) -> Optional[str]:
    """
    Attach image to the reply and set a CID so we can reference it in HTML.
    Returns cid string or None.
    """
    try:
        attach = reply_item.Attachments.Add(str(image_path))
        cid = f"img_{hashlib.sha1(str(image_path).encode('utf-8')).hexdigest()[:10]}@local"
        # PR_ATTACH_CONTENT_ID = 0x3712001E
        attach.PropertyAccessor.SetProperty("http://schemas.microsoft.com/mapi/proptag/0x3712001E", cid)
        return cid
    except Exception:
        return None


