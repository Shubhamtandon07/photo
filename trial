# --- CODE 1: Collect PDF + image attachments from .msg files (Notebook-safe) ---

from __future__ import annotations
from pathlib import Path
from datetime import datetime
import csv
import hashlib
import re
import traceback

# ========= CONFIG =========
ROOT = Path(r"C:\Users\SHTANDO\Desktop\chatbot")  # change if needed
INPUT_DIR = ROOT / "input"                        # folder that contains .msg files
EXPORTS_DIR = ROOT / "_exports"

# what we collect
PDF_EXTS = {".pdf"}
IMG_EXTS = {".png", ".jpg", ".jpeg", ".tif", ".tiff", ".bmp", ".gif", ".webp"}

# ========= HELPERS =========
def now_tag() -> str:
    return datetime.now().strftime("%Y%m%d_%H%M%S")

def safe_name(name: str, max_len: int = 80) -> str:
    name = (name or "").strip()
    name = re.sub(r"[<>:\"/\\|?*\x00-\x1F]+", "_", name)
    name = re.sub(r"\s+", " ", name).strip()
    if not name:
        name = "file"
    if len(name) > max_len:
        h = hashlib.sha1(name.encode("utf-8", errors="ignore")).hexdigest()[:8]
        base, dot, ext = name.rpartition(".")
        if dot:
            base = base[: max_len - (len(ext) + 1 + 9)]
            name = f"{base}__{h}.{ext}"
        else:
            name = f"{name[: max_len - 9]}__{h}"
    return name

def write_error(log_path: Path, msg: str):
    log_path.parent.mkdir(parents=True, exist_ok=True)
    with log_path.open("a", encoding="utf-8") as f:
        f.write(msg.rstrip() + "\n")

def import_extract_msg():
    try:
        import extract_msg  # type: ignore
        return extract_msg
    except Exception as e:
        raise RuntimeError(
            "Missing dependency: extract_msg. Install with:\n"
            "!python -m pip install --user -U extract-msg"
        ) from e

# ========= MAIN =========
def collect_attachments_from_msgs():
    extract_msg = import_extract_msg()

    input_dir = INPUT_DIR
    if not input_dir.exists():
        raise FileNotFoundError(f"INPUT_DIR not found: {input_dir}")

    # find .msg (recursive)
    msg_files = sorted([p for p in input_dir.rglob("*.msg") if p.is_file()])
    print("ROOT:", ROOT)
    print("INPUT_DIR:", input_dir)
    print("Found .msg files:", len(msg_files))

    run_dir = EXPORTS_DIR / f"collect_att_{now_tag()}"
    pdf_dir = run_dir / "pdfs"
    img_dir = run_dir / "images"
    pdf_dir.mkdir(parents=True, exist_ok=True)
    img_dir.mkdir(parents=True, exist_ok=True)

    manifest_path = run_dir / "manifest.csv"
    errors_path = run_dir / "errors.log"

    with manifest_path.open("w", newline="", encoding="utf-8") as f:
        w = csv.writer(f)
        w.writerow(["msg_file", "attachment_name", "saved_as", "type", "bytes"])

    ok_msgs = 0
    fail_msgs = 0
    saved = 0

    for msg_path in msg_files:
        try:
            m = extract_msg.Message(str(msg_path))
            # IMPORTANT: different extract_msg versions behave differently.
            # We avoid calling .process() and rely on lazy access.
            atts = getattr(m, "attachments", []) or []

            # Some versions require parsing by accessing subject/body first
            _ = getattr(m, "subject", None)

            # attachments list objects typically have:
            # .longFilename / .shortFilename, .data
            for att in atts:
                try:
                    fname = getattr(att, "longFilename", None) or getattr(att, "shortFilename", None) or "attachment"
                    ext = Path(fname).suffix.lower()

                    if ext in PDF_EXTS:
                        out_dir = pdf_dir
                        typ = "pdf"
                    elif ext in IMG_EXTS:
                        out_dir = img_dir
                        typ = "image"
                    else:
                        continue

                    data = getattr(att, "data", None)
                    if not data:
                        continue

                    out_name = safe_name(fname)
                    out_path = out_dir / out_name

                    # avoid overwrite collisions
                    if out_path.exists():
                        h = hashlib.sha1(data).hexdigest()[:8]
                        out_name = safe_name(f"{Path(out_name).stem}__{h}{Path(out_name).suffix}")
                        out_path = out_dir / out_name

                    out_path.write_bytes(data)
                    saved += 1

                    with manifest_path.open("a", newline="", encoding="utf-8") as f:
                        w = csv.writer(f)
                        w.writerow([msg_path.name, fname, out_name, typ, len(data)])

                except Exception as e_att:
                    write_error(errors_path, f"ATT_SAVE_ERROR | {msg_path.name} | {fname} -> {repr(e_att)}")

            ok_msgs += 1

        except Exception as e_msg:
            fail_msgs += 1
            write_error(errors_path, f"MSG_ERROR | {msg_path} -> {repr(e_msg)}")
            write_error(errors_path, traceback.format_exc())

    print("RUN_DIR:", run_dir)
    print(f"Done. MSG ok={ok_msgs} fail={fail_msgs} | attachments collected={saved}")
    print("Manifest:", manifest_path)
    print("Errors:", errors_path)
    print("PDFs folder:", pdf_dir)
    print("Images folder:", img_dir)

# Run it:
collect_attachments_from_msgs()

# --- CODE 2: Convert collected PDFs + images into DOCX (Notebook-safe) ---

from __future__ import annotations
from pathlib import Path
from datetime import datetime
import re
import traceback

# ========= CONFIG =========
RUN_DIR = Path(r"C:\Users\SHTANDO\Desktop\chatbot\_exports\collect_att_YYYYMMDD_HHMMSS")  # <-- set this
PDF_DIR = RUN_DIR / "pdfs"
IMG_DIR = RUN_DIR / "images"

OUT_DIR = RUN_DIR / f"docx_extracted_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
OUT_PDF = OUT_DIR / "from_pdfs"
OUT_IMG = OUT_DIR / "from_images"
OUT_PDF.mkdir(parents=True, exist_ok=True)
OUT_IMG.mkdir(parents=True, exist_ok=True)

ERRORS = OUT_DIR / "errors.log"

# ========= HELPERS =========
def write_error(msg: str):
    ERRORS.parent.mkdir(parents=True, exist_ok=True)
    with ERRORS.open("a", encoding="utf-8") as f:
        f.write(msg.rstrip() + "\n")

def safe_filename(name: str, max_len: int = 120) -> str:
    name = (name or "").strip()
    name = re.sub(r"[<>:\"/\\|?*\x00-\x1F]", "_", name)
    name = re.sub(r"\s+", " ", name).strip()
    if not name:
        name = "file"
    return name[:max_len]

def import_docx():
    try:
        from docx import Document  # type: ignore
        return Document
    except Exception as e:
        raise RuntimeError("Missing dependency: python-docx. Install: !python -m pip install --user python-docx") from e

def import_pdfplumber():
    try:
        import pdfplumber  # type: ignore
        return pdfplumber
    except Exception:
        return None

def import_pytesseract_and_pil():
    try:
        import pytesseract  # type: ignore
        from PIL import Image  # type: ignore
        return pytesseract, Image
    except Exception:
        return None, None

def normalize_cell(x) -> str:
    if x is None:
        return ""
    s = str(x).replace("\u00a0", " ")
    s = re.sub(r"\s+", " ", s).strip()
    return s

def add_table(doc, table_data):
    # table_data: list[list[str]]
    if not table_data:
        return
    rows = [r for r in table_data if isinstance(r, list)]
    if len(rows) < 2:
        return
    cols = max(len(r) for r in rows)
    if cols < 2:
        return

    t = doc.add_table(rows=len(rows), cols=cols)
    t.style = "Table Grid"
    for i, r in enumerate(rows):
        r = list(r) + [""] * (cols - len(r))
        for j, c in enumerate(r):
            t.cell(i, j).text = normalize_cell(c)
    doc.add_paragraph("")

# ========= PDF -> DOCX =========
def pdf_to_docx(pdf_path: Path, out_docx: Path):
    Document = import_docx()
    pdfplumber = import_pdfplumber()
    if pdfplumber is None:
        raise RuntimeError("pdfplumber is missing. Install: !python -m pip install --user pdfplumber")

    doc = Document()
    doc.add_heading(f"{pdf_path.name}", level=1)
    doc.add_paragraph(f"Source: {pdf_path}")

    with pdfplumber.open(str(pdf_path)) as pdf:
        for i, page in enumerate(pdf.pages, start=1):
            doc.add_heading(f"Page {i}", level=2)

            # 1) Try tables first (best effort)
            try:
                tables = page.extract_tables() or []
            except Exception:
                tables = []

            if tables:
                doc.add_paragraph("Tables:")
                for tbl in tables:
                    add_table(doc, tbl)

            # 2) Then plain text
            try:
                txt = page.extract_text() or ""
            except Exception:
                txt = ""

            txt = txt.strip()
            if txt:
                doc.add_paragraph("Text:")
                for line in txt.splitlines():
                    line = line.strip()
                    if line:
                        doc.add_paragraph(line)
            else:
                doc.add_paragraph("(No readable text on this page.)")

            doc.add_page_break()

    doc.save(str(out_docx))

# ========= IMAGE -> DOCX (OCR) =========
def image_to_docx(img_path: Path, out_docx: Path):
    Document = import_docx()
    pytesseract, Image = import_pytesseract_and_pil()
    if pytesseract is None or Image is None:
        raise RuntimeError(
            "OCR not available (missing pytesseract/Pillow). "
            "Install: !python -m pip install --user pytesseract pillow"
        )

    doc = Document()
    doc.add_heading(f"{img_path.name}", level=1)
    doc.add_paragraph(f"Source: {img_path}")

    try:
        img = Image.open(img_path)
        text = pytesseract.image_to_string(img)
    except Exception as e:
        raise RuntimeError(f"OCR failed: {repr(e)}")

    text = (text or "").strip()
    if text:
        for line in text.splitlines():
            line = line.strip()
            if line:
                doc.add_paragraph(line)
    else:
        doc.add_paragraph("(No readable text found by OCR.)")

    doc.save(str(out_docx))

# ========= RUN =========
def run_convert():
    pdfs = sorted([p for p in PDF_DIR.glob("*.pdf") if p.is_file()])
    imgs = sorted([p for p in IMG_DIR.glob("*") if p.is_file() and p.suffix.lower() in {".png",".jpg",".jpeg",".tif",".tiff",".bmp",".gif",".webp"}])

    print("RUN_DIR:", RUN_DIR)
    print("PDFs found:", len(pdfs))
    print("Images found:", len(imgs))
    print("OUT_DIR:", OUT_DIR)

    ok = fail = 0

    for p in pdfs:
        out = OUT_PDF / safe_filename(p.stem + ".docx")
        try:
            pdf_to_docx(p, out)
            ok += 1
        except Exception as e:
            fail += 1
            write_error(f"PDF_FAIL | {p.name} -> {repr(e)}")
            write_error(traceback.format_exc())

    for p in imgs:
        out = OUT_IMG / safe_filename(p.stem + ".docx")
        try:
            image_to_docx(p, out)
            ok += 1
        except Exception as e:
            fail += 1
            write_error(f"IMG_FAIL | {p.name} -> {repr(e)}")
            write_error(traceback.format_exc())

    print(f"Done. ok={ok} fail={fail}")
    print("Errors:", ERRORS)

# Run it:
run_convert()
