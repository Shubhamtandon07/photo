def build_fallback_email(question: str, greeting_name: str, signature_name: str, sources: List[str], findings: List[Tuple[str,str,bool]]) -> str:
    subj = "Antwort auf Ihre Frage"
    if "fokusprämissen" in question.lower():
        subj = "Fokusprämissen Nachhaltigkeit – Umweltbezogene Anforderungen"
    elif "standard" in question.lower() or "norm" in question.lower():
        subj = "Standards / Normen – Klärung"

    # Take top 8 most relevant lines (already ranked upstream)
    top_lines = [ln for _, ln, _ in findings[:8]]

    de = []
    de.append(f"Betreff: {subj}")
    de.append(f"Hallo {greeting_name},")
    de.append("ich hoffe, es geht Ihnen gut.")
    de.append("")
    if top_lines:
        de.append("Nachfolgend die relevanten Punkte aus den Unterlagen:")
        for i, ln in enumerate(top_lines, start=1):
            de.append(f"{i}) {ln}")
    else:
        de.append("Ich konnte in den aktuell geladenen Dokumenten keine belastbaren Aussagen zur Frage finden.")
        de.append("Können Sie bitte den Dokumentennamen oder den relevanten Abschnitt nennen?")
    de.append("")
    if sources:
        de.append("Sources used: " + ", ".join(sources))
    de.append("Mit freundlichen Grüßen")
    de.append(signature_name)

    en = []
    en.append(f"Subject: {subj}")
    en.append(f"Hello {greeting_name},")
    en.append("I hope you are doing well.")
    en.append("")
    if top_lines:
        en.append("Below are the relevant points found in the documents:")
        for i, ln in enumerate(top_lines, start=1):
            en.append(f"{i}) {ln}")
    else:
        en.append("I could not find well-supported statements for this question in the currently loaded documents.")
        en.append("Could you please point to the specific document or section?")
    en.append("")
    if sources:
        en.append("Sources used: " + ", ".join(sources))
    en.append("Best regards,")
    en.append(signature_name)

    return "\n".join(de).strip() + "\n\n---\n\n" + "\n".join(en).strip()


