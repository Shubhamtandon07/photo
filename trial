def build_llm_prompt(question: str, greeting_name: str, signature_name: str, sources: List[str], findings_text: str) -> str:
    src_line = ", ".join(sources) if sources else "(none)"
    return f"""
You are drafting a professional corporate email reply in procurement/sustainability context.

STRICT GROUNDING:
- Use ONLY the FINDINGS below. Do NOT invent facts.
- Answer ONLY the user’s question.

OUTPUT (must follow):
1) First German section
2) Line with exactly: ---
3) Then English section

STYLE (Copilot-like):
- Start with a clear SUBJECT line:
  German: "Betreff: <short subject>"
  English: "Subject: <short subject>"
- Then greeting + 1 short intro sentence.
- Then numbered sections (1..N) with short headings (only include sections supported by findings).
  Each section should be 2–4 lines max.
- If there are deadlines/platforms/templates mentioned in findings, include them.
- End with a short closing sentence offering clarification.
- Add "Sources used: <doc titles only>" at the end of each language section.
- Add a short summary only if the answer is long (>140 words) or has >4 sections:
  German: "Kurzfassung:" with 2–4 bullets
  English: "Short summary:" with 2–4 bullets

SAFETY:
- Do NOT output personal names, supplier names, emails, phones, addresses, IDs.
- MAIL-CHAIN findings may be used ONLY if they contain near-identical past Q&A that directly answers the question or show typical MB phrasing.

Greeting/closing:
- German starts with: "Hallo {greeting_name},"
- German ends with: "Mit freundlichen Grüßen" + "{signature_name}"
- English starts with: "Hello {greeting_name},"
- English ends with: "Best regards," + "{signature_name}"

Question:
{question}

Allowed sources list (use only these for Sources used):
{src_line}

FINDINGS:
{findings_text if findings_text.strip() else "(no findings)"}
""".strip()


def build_azure_client() -> AzureOpenAI:
    key = os.getenv("OPENAI_API_KEY", "").strip()
    if not key:
        raise SystemExit("OPENAI_API_KEY env var missing (GenAI-Nexus key).")
    return AzureOpenAI(
        api_key=key,
        azure_endpoint=AZURE_OPENAI_ENDPOINT,
        api_version=AZURE_API_VERSION,
    )

def _extract_chat_text(resp) -> str:
    """
    Robustly extract text from ChatCompletions response.
    Handles string OR list-of-parts formats.
    """
    try:
        msg = resp.choices[0].message
    except Exception:
        return ""

    content = getattr(msg, "content", None)

    if isinstance(content, str):
        return content.strip()

    # Some deployments may return list parts like: [{"type":"text","text":"..."}]
    if isinstance(content, list):
        parts = []
        for p in content:
            if isinstance(p, str):
                parts.append(p)
            elif isinstance(p, dict):
                if "text" in p and isinstance(p["text"], str):
                    parts.append(p["text"])
            else:
                t = getattr(p, "text", None)
                if isinstance(t, str):
                    parts.append(t)
        return "\n".join(parts).strip()

    return ""

def call_llm(client: AzureOpenAI, prompt: str) -> str:
    resp = client.chat.completions.create(
        model=AZURE_DEPLOYMENT_NAME,
        temperature=LLM_TEMPERATURE,
        max_completion_tokens=LLM_MAX_COMPLETION_TOKENS,
        messages=[
            {"role": "system", "content": "Follow the required format exactly. Use only FINDINGS."},
            {"role": "user", "content": prompt},
        ],
    )
    return _extract_chat_text(resp)


