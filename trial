def build_azure_client() -> AzureOpenAI:
    key = os.getenv("OPENAI_API_KEY", "").strip()
    if not key:
        raise SystemExit("OPENAI_API_KEY env var missing (set it in notebook session or OS env).")
    return AzureOpenAI(
        api_key=key,
        azure_endpoint=AZURE_OPENAI_ENDPOINT,
        api_version=AZURE_API_VERSION,
    )

def call_llm(client: AzureOpenAI, prompt: str) -> str:
    # GPT-5.1 expects max_completion_tokens, not max_tokens
    resp = client.chat.completions.create(
        model=AZURE_DEPLOYMENT_NAME,
        temperature=LLM_TEMPERATURE,
        max_completion_tokens=LLM_MAX_COMPLETION_TOKENS,
        messages=[
            {"role": "system", "content": "Follow instructions exactly. Use only provided extracted pack."},
            {"role": "user", "content": prompt},
        ],
    )
    return (resp.choices[0].message.content or "").strip()

