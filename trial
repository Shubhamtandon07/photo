def run_bot_once():
    if PRINT_RUN_TIMESTAMP:
        print("\n=== RUN START ===")
        print("Run timestamp:", datetime.now().strftime("%Y-%m-%d %H:%M:%S"))
        print("=================\n")

    time.sleep(STARTUP_DELAY_SEC)

    print("Loading KB docs from:", KB_DIR)
    docs = load_kb_docs(KB_DIR)
    print("KB docs:", len(docs))

    client = build_azure_client()

    ns, folder, store_name, folder_name = get_target_folder()
    print(f"Mailbox={store_name} | Folder={folder_name}")

    items = folder.Items
    items.Sort("[ReceivedTime]", True)

    drafted = 0
    checked = 0

    signature_name = FORCE_SIGNATURE_NAME or safe_firstname_from_email(TARGET_MAILBOX)

    for mail in items:
        checked += 1
        if checked > SCAN_LIMIT:
            break
        if drafted >= PROCESS_PER_RUN:
            break

        try:
            if getattr(mail, "Class", None) != 43:
                continue

            if PROCESSED_CATEGORY.lower() in (mail.Categories or "").lower():
                continue

            if REQUIRE_UNREAD and not mail.UnRead:
                continue

            subject = mail.Subject or ""
            if not strict_subject_ok(subject):
                continue

            sender = get_sender_smtp(mail)
            greeting_name = safe_firstname_from_email(sender)

            body_text = clean_html_to_text(mail.HTMLBody or "")
            question = re.split(r"(?i)\b(von:|from:|gesendet:|sent:|-----original message-----)\b", body_text)[0].strip()
            if not question:
                question = body_text.strip()
            question = clean_question(question)

            print("\n[PASS] bot mail:", sender)
            print("Question:", question)

            # Pass A: non-mail docs
            topA = rank_docs_simple(docs, question, include_maily=False, top_k=TOP_DOCS_PASS_A)

            # Pass B: mail docs (secondary)
            mail_candidates = []
            if TOP_DOCS_PASS_B > 0:
                topB = rank_docs_simple(docs, question, include_maily=True, top_k=40)
                mail_candidates = [d for d in topB if d[4] is True][:TOP_DOCS_PASS_B]

            top_docs = topA + mail_candidates
            print("Top docs:", [d[2] for d in top_docs])

            # Try FULL -> SMALL -> TINY
            attempt_plan = [
                ("FULL", FINDINGS_FULL),
                ("SMALL", FINDINGS_SMALL),
                ("TINY", FINDINGS_TINY),
            ]

            reply_text = ""

            for label, n_lines in attempt_plan:
                findings, sources = build_requirement_pack(top_docs, question, max_lines=n_lines)
                findings_text = build_findings_text(findings)

                print(f"Findings pack {label}: lines={len(findings)} sources={sources}")

                prompt = build_llm_prompt(
                    question=question,
                    greeting_name=greeting_name,
                    signature_name=signature_name,
                    sources=sources,
                    findings_text=findings_text,
                )

                reply_text, _ = call_llm(client, prompt)
                print(f"LLM reply len ({label}):", len(reply_text))
                if DEBUG_PRINT_LLM_PREVIEW:
                    print("LLM preview:", repr(reply_text[:220]))

                if reply_text.strip():
                    break

            # If still empty -> general guidance LLM (still LLM, always answers)
            if not reply_text.strip():
                print("WARNING: grounded LLM output blanked. Using GENERAL LLM fallback (still LLM).")
                prompt_general = build_general_llm_prompt(
                    question=question,
                    greeting_name=greeting_name,
                    signature_name=signature_name,
                )
                reply_text, _ = call_llm(client, prompt_general)
                print("LLM reply len (GENERAL):", len(reply_text))

                if reply_text.strip():
                    if looks_english(question):
                        note = "Note: The following is general guidance; please validate against the latest internal sustainability-awarding documents."
                        reply_text = reply_text + "\n\n" + note
                    else:
                        note = "Hinweis: Folgendes ist allgemeine Orientierung; bitte gegen die neuesten internen Nachhaltigkeits-/Vergabe-Dokumente validieren."
                        reply_text = reply_text + "\n\n" + note

            # Absolute last fallback (deterministic)
            if not reply_text.strip():
                print("WARNING: LLM still empty. Using deterministic fallback.")
                reply_text = (
                    f"Hello {greeting_name},\n"
                    f"I could not generate a response from the current document excerpts.\n"
                    f"Could you please point to the exact internal document/section you mean?\n\n"
                    f"Best regards,\n{signature_name}\n\n---\n\n"
                    f"Hallo {greeting_name},\n"
                    f"ich konnte aus den aktuell gefundenen Dokumentstellen keine Antwort generieren.\n"
                    f"Können Sie bitte den konkreten Dokumentnamen oder Abschnitt nennen?\n\n"
                    f"Mit freundlichen Grüßen\n{signature_name}"
                )

            # >>> YOUR TWO REQUIREMENTS:
            # 1) remove Subject/Betreff lines if the model included them anyway
            reply_text = strip_subject_lines(reply_text)

            # 2) ensure greeting exists if model forgot
            reply_text = ensure_greetings(reply_text, greeting_name=greeting_name, english_first=looks_english(question))

            # Render bold and HTML
            reply_text_html_ready = md_bold_to_html(reply_text)

            reply = mail.Reply()
            reply.HTMLBody = f"<div>{format_outlook_html(reply_text_html_ready)}</div><hr>" + reply.HTMLBody
            reply.Save()

            mark_read(mail)
            add_processed_category(mail)

            drafted += 1
            print("Draft created for:", subject)

            if SELF_NOTIFY:
                send_self_notification(ns, TARGET_MAILBOX, SELF_NOTIFY_TO, subject, sender)

            if CREATE_REMINDER_TASK:
                create_outlook_task_reminder(ns, subject=subject, days=REMINDER_DAYS)

        except Exception as e:
            print("Mail error:", getattr(mail, "Subject", "<no subject>"), "-", repr(e))

    print(f"\nDone. Checked={checked}, Drafted={drafted}")


# Notebook: run_bot_once()
if __name__ == "__main__":
    run_bot_once()
