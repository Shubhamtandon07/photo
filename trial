def build_azure_client() -> AzureOpenAI:
    key = os.getenv("OPENAI_API_KEY", "").strip()
    if not key:
        raise SystemExit("OPENAI_API_KEY env var missing (GenAI-Nexus key).")
    return AzureOpenAI(
        api_key=key,
        azure_endpoint=AZURE_OPENAI_ENDPOINT,
        api_version=AZURE_API_VERSION,
    )


def _extract_chat_text(resp) -> str:
    try:
        mc = resp.choices[0].message.content
        if isinstance(mc, str):
            return mc.strip()
    except Exception:
        pass
    try:
        d = resp.model_dump()
        s = d.get("choices", [{}])[0].get("message", {}).get("content", "")
        return (s or "").strip()
    except Exception:
        return ""


def call_llm(client: AzureOpenAI, prompt: str) -> Tuple[str, Any]:
    resp = client.chat.completions.create(
        model=AZURE_DEPLOYMENT_NAME,
        temperature=LLM_TEMPERATURE,
        max_completion_tokens=LLM_MAX_COMPLETION_TOKENS,
        messages=[
            {"role": "system", "content": "Follow the required format exactly. Facts only from DOC FINDINGS."},
            {"role": "user", "content": prompt},
        ],
    )
    txt = _extract_chat_text(resp)

    if DEBUG_PRINT_LLM_META:
        try:
            fr = getattr(resp.choices[0], "finish_reason", None)
            print("DEBUG finish_reason:", fr)
        except Exception:
            pass

    if DEBUG_PRINT_LLM_PREVIEW:
        try:
            mc = resp.choices[0].message.content
            print("DEBUG message.content type:", type(mc))
        except Exception:
            print("DEBUG could not inspect message.content")

    return (txt or "").strip(), resp


