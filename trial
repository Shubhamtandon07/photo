def extract_text_from_chat(resp) -> str:
    msg = resp.choices[0].message
    c = getattr(msg, "content", None)

    if isinstance(c, str):
        return c.strip()

    if isinstance(c, list):
        parts = []
        for p in c:
            if isinstance(p, dict):
                t = p.get("text") or p.get("output_text")
                if isinstance(t, str) and t.strip():
                    parts.append(t.strip())
            else:
                t = getattr(p, "text", None) or getattr(p, "output_text", None)
                if isinstance(t, str) and t.strip():
                    parts.append(t.strip())
        return "\n".join(parts).strip()

    # last resort
    try:
        d = resp.model_dump()
        # pick longest string among common keys
        cand = []
        def walk(x):
            if isinstance(x, dict):
                for k,v in x.items():
                    if k in ("text","content","output_text") and isinstance(v,str) and v.strip():
                        cand.append(v.strip())
                    else:
                        walk(v)
            elif isinstance(x, list):
                for it in x:
                    walk(it)
        walk(d)
        cand.sort(key=len, reverse=True)
        return cand[0].strip() if cand else ""
    except Exception:
        return ""
