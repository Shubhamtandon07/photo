def doc_priority_adjustment(filename: str) -> float:
    """
    Higher is better. Mail-chain docs heavily penalized but not forbidden.
    """
    fn = (filename or "").lower()
    score = 0.0
    if fn.startswith(MAILY_PREFIXES):
        score -= 0.60  # strong demotion
    if any(h in fn for h in MAILY_HINTS):
        score -= 0.25
    # boost authoritative terms
    if re.search(r"(?i)\b(mbn|din|iso|vda|standard|policy|guideline|kapitel|chapter|requirements)\b", fn):
        score += 0.20
    return score

def _try_import_sklearn():
    try:
        from sklearn.feature_extraction.text import TfidfVectorizer  # type: ignore
        from sklearn.metrics.pairwise import cosine_similarity       # type: ignore
        return TfidfVectorizer, cosine_similarity
    except Exception:
        return None, None

TFIDF_VECTORIZER, COSINE_SIM = _try_import_sklearn()

def rank_docs(chunks: List[Chunk], query: str, include_maily: bool) -> List[Tuple[float, str, str]]:
    """
    Returns list of (score, fullpath, filename) unique docs.
    """
    query = clean_ws(query)
    if not query:
        return []

    # group chunks by doc
    doc_map = {}
    for c in chunks:
        if not include_maily and c.is_maily:
            continue
        doc_map.setdefault((c.fullpath, c.filename), []).append(c.text)

    docs = list(doc_map.keys())
    texts = ["\n\n".join(doc_map[d])[:60_000] for d in docs]  # cap for TFIDF

    scored: List[Tuple[float, str, str]] = []

    if TFIDF_VECTORIZER and COSINE_SIM and texts:
        vec = TFIDF_VECTORIZER(min_df=1, ngram_range=(1, 2), max_features=80_000)
        X = vec.fit_transform(texts)
        qv = vec.transform([query])
        sims = COSINE_SIM(qv, X).ravel()
        for (fullpath, fname), sim in zip(docs, sims):
            score = float(sim) + doc_priority_adjustment(fname)
            scored.append((score, fullpath, fname))
        scored.sort(key=lambda x: x[0], reverse=True)
        return scored

    # fallback: token overlap on concatenated doc text
    q_toks = set(tokenize(query))
    for (fullpath, fname), t in zip(docs, texts):
        tl = t.lower()
        overlap = sum(1 for tk in q_toks if tk in tl)
        base = overlap / max(1, len(q_toks))
        score = float(base) + doc_priority_adjustment(fname)
        scored.append((score, fullpath, fname))
    scored.sort(key=lambda x: x[0], reverse=True)
    return scored

def rank_chunks(chunks: List[Chunk], query: str, top_docs: List[Tuple[float, str, str]], top_k: int) -> List[Tuple[float, Chunk]]:
    """
    Rank chunks within the selected docs.
    """
    query = clean_ws(query)
    if not query:
        return []

    doc_set = set((fp, fn) for _, fp, fn in top_docs)
    pool = [c for c in chunks if (c.fullpath, c.filename) in doc_set]

    if not pool:
        return []

    if TFIDF_VECTORIZER and COSINE_SIM:
        vec = TFIDF_VECTORIZER(min_df=1, ngram_range=(1, 2), max_features=90_000)
        X = vec.fit_transform([c.text for c in pool])
        qv = vec.transform([query])
        sims = COSINE_SIM(qv, X).ravel()
        scored = []
        doc_score_map = {(fp, fn): ds for ds, fp, fn in top_docs}
        for c, sim in zip(pool, sims):
            score = float(sim) + doc_score_map.get((c.fullpath, c.filename), 0.0) * 0.10
            scored.append((score, c))
        scored.sort(key=lambda x: x[0], reverse=True)
        return scored[:top_k]

    # fallback overlap scoring
    q_toks = set(tokenize(query))
    scored = []
    doc_score_map = {(fp, fn): ds for ds, fp, fn in top_docs}
    for c in pool:
        tl = c.text.lower()
        overlap = sum(1 for tk in q_toks if tk in tl)
        score = overlap + doc_score_map.get((c.fullpath, c.filename), 0.0) * 0.10
        scored.append((float(score), c))
    scored.sort(key=lambda x: x[0], reverse=True)
    return scored[:top_k]

def anchor_scan_best_sentence(chunks_scored: List[Tuple[float, Chunk]], query: str) -> Optional[Tuple[str, Chunk]]:
    """
    Strong fallback for "which standard" questions.
    Picks sentence containing ISO/DIN/MBN/VDA/etc + overlap.
    """
    ql = query.lower()
    if not any(k in ql for k in ["which standard", "welche norm", "welchem standard", "gemäß", "according to", "in accordance"]):
        return None

    anchor_re = re.compile(r"(?i)\b(MBN\s*\d{3,6}|DIN\s*\w+|ISO\s*\d{3,6}|VDA\s*\d+)\b")

    def sentence_split(text: str) -> List[str]:
        txt = re.sub(r"\s+", " ", text or "").strip()
        if not txt:
            return []
        parts = re.split(r"(?<=[\.\!\?])\s+", txt)
        return [p.strip(" -•\t\r\n") for p in parts if len(p.strip()) >= 10]

    q_toks = set(tokenize(query))
    best = None
    best_score = -1

    for score, c in chunks_scored:
        for sent in sentence_split(c.text):
            if not anchor_re.search(sent):
                continue
            stoks = set(tokenize(sent))
            ov = len(q_toks & stoks)
            s = ov * 10 + (5 if "shall" in sent.lower() or "muss" in sent.lower() else 0)
            if s > best_score:
                best_score = s
                best = (sent.strip(), c)

    return best

def retrieve_evidence(all_chunks: List[Chunk], question: str) -> Tuple[List[Chunk], List[str]]:
    """
    Two-pass retrieval:
    Pass A: non-mail docs only
    Pass B: include mail docs if A is weak
    Returns: (selected_chunks, source_ids)
    """
    q = clean_ws(question)
    if not q:
        return [], []

    # Pass A
    docs_A = rank_docs(all_chunks, q, include_maily=(not PASSA_ONLY_NON_MAIL_DOCS))
    top_docs_A = docs_A[:DOC_TOP_K]
    chunks_A = rank_chunks(all_chunks, q, top_docs_A, top_k=CHUNK_TOP_K)

    selected_A = [c for _, c in chunks_A]
    sources_A = [c.chunk_id for c in selected_A]

    # If A has at least some decent evidence, keep it.
    if selected_A:
        return selected_A, sources_A

    # Pass B: include mail docs (still penalized) if enabled
    if FALLBACK_PASSB_INCLUDE_MAIL_DOCS:
        docs_B = rank_docs(all_chunks, q, include_maily=True)
        top_docs_B = docs_B[:max(DOC_TOP_K, 25)]
        chunks_B = rank_chunks(all_chunks, q, top_docs_B, top_k=max(CHUNK_TOP_K, 100))
        selected_B = [c for _, c in chunks_B]
        sources_B = [c.chunk_id for c in selected_B]
        return selected_B, sources_B

    return [], []

