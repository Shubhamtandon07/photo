def build_llm_prompt(question: str, greeting_name: str, signature_name: str, sources: List[str], evidence: str) -> str:
    src_line = ", ".join(sources) if sources else "(none)"
    return f"""
You are drafting a professional email reply for corporate procurement/sustainability context.

HARD RULES (follow strictly):
- Use ONLY the evidence snippets provided below. Do not invent facts.
- Answer ONLY what the user asked. Do NOT add adjacent topics unless strictly required to answer the question.
- Extract ALL relevant requirements/steps/definitions from the evidence that directly answer the question (do not stop at 1–2 points if there are more).
- If evidence is insufficient, ask 1–2 short clarifying questions instead of guessing.
- Output MUST be bilingual: German first, then a separator line '---', then English.
- Keep it human and presentable; be concise but complete.
- Use paragraphs. Use bullet points only when there are multiple items/steps.
- Do NOT include personal names, supplier names, email addresses, phone numbers, postal addresses, IDs, internal org codes, or money amounts.
- Mail-chain evidence (marked MAIL-CHAIN) is allowed ONLY as secondary support:
  - to mirror typical Mercedes reply style, or
  - if it contains an identical/near-identical past Q&A that directly answers the question.
  Prefer DOC evidence for the factual answer.

SUMMARY RULE:
- If the answer section is longer than ~120 words OR has more than 3 bullets, add at the end of EACH language section:
  "Kurzfassung:" (DE) / "Short summary:" (EN) with 2–4 bullets.
- If the answer is already short, DO NOT add a summary.

Greeting/closing:
- German starts with: "Hallo {greeting_name},"
- German ends with: "Mit freundlichen Grüßen" + "{signature_name}"
- English starts with: "Hello {greeting_name},"
- English ends with: "Best regards," + "{signature_name}"

At the end of EACH language section include:
"Sources used: <doc titles only from allowed list>" (no emails).

Question:
{question}

Allowed sources list (use for "Sources used"):
{src_line}

Evidence snippets:
{evidence}
""".strip()


def build_azure_client() -> AzureOpenAI:
    key = os.getenv("OPENAI_API_KEY", "").strip()
    if not key:
        raise SystemExit("OPENAI_API_KEY env var missing (GenAI-Nexus key).")
    return AzureOpenAI(
        api_key=key,
        azure_endpoint=AZURE_OPENAI_ENDPOINT,
        api_version=AZURE_API_VERSION,
    )


def call_llm(client: AzureOpenAI, prompt: str) -> str:
    resp = client.chat.completions.create(
        model=AZURE_DEPLOYMENT_NAME,
        temperature=LLM_TEMPERATURE,
        max_completion_tokens=LLM_MAX_TOKENS,
        messages=[
            {"role": "system", "content": "You must follow the hard rules. Use only provided evidence."},
            {"role": "user", "content": prompt},
        ],
    )
    return (resp.choices[0].message.content or "").strip()


