REQ_WORDS = re.compile(
    r"(?i)\b(must|shall|required|requirement|within|by|submit|complete|provide|ensure|obliged|"
    r"muss|soll|erforder|anforderung|innerhalb|bis|einreichen|ausfÃžllen|bereitstellen|sicherstellen|verpflichtet)\b"
)

TIME_WORDS = re.compile(r"(?i)\b(within\s+\d+|by\s+\d+|bis\s+\d+|innerhalb\s+\d+|weeks?|wochen?|tage?|days?)\b")
PLATFORM_WORDS = re.compile(r"(?i)\b(platform|portal|template|vorlage|certus|supplierassurance|docmaster|prosource|smaragd|nx)\b")
STANDARD_WORDS = re.compile(r"(?i)\b(MBN\s*\d{3,6}|DIN\s*\w+|ISO\s*\d{3,6}|VDA\s*\d+)\b")

def split_sentences_loose(text: str) -> List[str]:
    t = (text or "").replace("\n", " ")
    t = re.sub(r"\s+", " ", t).strip()
    if not t:
        return []
    # keep semi-colon splits too
    parts = re.split(r"(?<=[\.\!\?])\s+|;\s+", t)
    out = []
    for p in parts:
        p = p.strip(" -âĒ\t\r\n")
        if len(p) >= 20:
            out.append(p)
    return out

def cleanup_pipe_noise(s: str) -> str:
    """
    Fix docx table lines that became: 'foo | foo | foo | bar'
    Keep only meaningful unique tokens and remove obvious repetition.
    """
    s = clean_ws(s)
    if "|" not in s:
        return s
    parts = [clean_ws(x) for x in s.split("|")]
    # drop empties and exact duplicates while preserving order
    seen = set()
    keep = []
    for p in parts:
        key = p.lower()
        if not p:
            continue
        if key in seen:
            continue
        seen.add(key)
        keep.append(p)
    # If still too many fragments, join first 2-3 plus last (often bilingual)
    if len(keep) > 10:
        keep = keep[:3] + (keep[-2:] if len(keep) >= 2 else [])
    return " | ".join(keep)

def classify_section(sentence: str) -> str:
    s = sentence.lower()
    # Copilot-like buckets (extend as you like)
    if any(k in s for k in ["tier", "lieferkette", "supply chain", "transparen", "origin", "herkunft"]):
        return "Supply Chain Transparency / Lieferkettentransparenz"
    if any(k in s for k in ["saq", "supplierassurance", "self assessment", "questionnaire", "assessment"]):
        return "Sustainability Assessment (SAQ)"
    if any(k in s for k in ["ddq", "due diligence", "sorgfalt", "human rights", "menschenrecht"]):
        return "Due Diligence / Sorgfaltspflichten"
    if any(k in s for k in ["3tg", "cmrt", "rmap", "tin", "tantal", "tungsten", "gold"]):
        return "3TG Materials / 3TG-Materialien"
    if any(k in s for k in ["co2", "carbon", "emission", "grÃžnstrom", "ppa", "renewable electricity"]):
        return "COâ & Energy / COâ & Energie"
    if any(k in s for k in ["recycled", "rezyklat", "sekundÃĪrmaterial", "secondary material"]):
        return "Recycled / Secondary Material"
    if any(k in s for k in ["documented", "documentation", "dokumentation", "smaragd", "nx", "3d record"]):
        return "Documentation / Dokumentation"
    return "General Requirements / Allgemeine Anforderungen"

def extract_requirements(best_chunks, query: str) -> Dict[str, List[Tuple[str, str]]]:
    """
    Returns dict:
      section -> list of (requirement_sentence, source_chunk_id)
    Selects requirement-like sentences strongly related to query tokens.
    """
    q_tokens = set(tokenize(query))
    extracted: Dict[str, List[Tuple[str, str]]] = {}

    for _, _, fname, cid, ch in best_chunks:
        # break chunk into sentences
        for sent in split_sentences_loose(ch):
            sent2 = cleanup_pipe_noise(sent)

            # must look like a requirement OR contain standard reference for "which standard" questions
            is_req = bool(REQ_WORDS.search(sent2)) or bool(TIME_WORDS.search(sent2)) or bool(PLATFORM_WORDS.search(sent2))
            is_std = bool(STANDARD_WORDS.search(sent2))

            if not (is_req or is_std):
                continue

            # must have some overlap with query to prevent random quoting
            stoks = set(tokenize(sent2))
            overlap = len(q_tokens & stoks)
            if overlap < max(1, min(2, len(q_tokens)//6)):
                # allow standards questions with standard refs even if overlap low
                if not (is_std and re.search(r"(?i)\b(which|welche|welchem|standard|norm|gemÃĪÃ|in accordance)\b", query)):
                    continue

            section = classify_section(sent2)
            extracted.setdefault(section, []).append((sent2, cid))

    # Deduplicate within each section (by lowercase sentence)
    for sec in list(extracted.keys()):
        seen = set()
        uniq = []
        for s, cid in extracted[sec]:
            k = s.lower()
            if k in seen:
                continue
            seen.add(k)
            uniq.append((s, cid))
        extracted[sec] = uniq

    return extracted

def build_extraction_pack(extracted: Dict[str, List[Tuple[str, str]]], max_per_section: int = 4) -> str:
    """
    What we feed into the LLM: structured, clean, finite.
    """
    if not extracted:
        return "(no extracted requirements)"

    lines = []
    for sec in extracted.keys():
        items = extracted[sec][:max_per_section]
        if not items:
            continue
        lines.append(f"## {sec}")
        for s, cid in items:
            lines.append(f"- {s}  [source: {cid}]")
        lines.append("")
    return "\n".join(lines).strip()

