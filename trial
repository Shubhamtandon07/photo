def lese_liste(pfad):
    if not pfad.exists():
        return []
    out = []
    with pfad.open("r", encoding="utf-8-sig") as f:
        r = csv.reader(f)
        for row in r:
            for cell in row:
                v = cell.strip().lower()
                if v:
                    out.append(v)
    return list(dict.fromkeys(out))


