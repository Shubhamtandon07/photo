def score_chunk(query: str, chunk_text: str, filename: str) -> float:
    q_toks = tokenize(query)
    if not q_toks:
        return 0.0
    t = chunk_text.lower()

    overlap = 0
    for tk in set(q_toks):
        if tk in t:
            overlap += 1

    # anchor bonus for standards questions
    anchor_bonus = 0
    if re.search(r"(?i)\b(which|welche|welchem|in accordance|gemÃĪÃ|standard|norm)\b", query):
        if re.search(r"(?i)\b(MBN\s*\d{3,6}|DIN\s*\w+|ISO\s*\d{3,6}|VDA\s*\d+)\b", chunk_text):
            anchor_bonus = 3

    # requirement bonus
    req_bonus = 0
    if re.search(r"(?i)\b(must|shall|required|requirement|within|by|submit|complete|template|platform|muss|soll|erforder|anforder|innerhalb|bis|einreichen|ausfÃžllen|vorlage|plattform)\b", chunk_text):
        req_bonus = 2

    base = overlap + req_bonus + anchor_bonus
    base += doc_priority_adjustment(filename) * 10.0
    return float(base)

def pick_best_chunks(kb_chunks: List[Tuple[str, str, str, str]], query: str, top_k: int = TOP_K_CHUNKS):
    scored = []
    for fullpath, fname, cid, ch in kb_chunks:
        s = score_chunk(query, ch, fname)
        if s > 0:
            scored.append((s, fullpath, fname, cid, ch))
    scored.sort(key=lambda x: x[0], reverse=True)
    return scored[:top_k]

