import requests

LIBRE_URL = "PASTE_LIBRETRANSLATE_BASE_URL_HERE"  # e.g. https://libretranslate.example.com
payload = {
    "q": "Das ist ein Test. Bitte übersetzen.",
    "source": "de",
    "target": "en",
    "format": "text",
}
r = requests.post(f"{LIBRE_URL.rstrip('/')}/translate", data=payload, timeout=30)
print("status:", r.status_code)
print("response:", r.text[:500])
