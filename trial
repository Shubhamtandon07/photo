# =========================
# 5) LOAD SITE LIST
# =========================
def lese_liste(pfad):
    if not pfad.exists():
        return []
    out = []
    with pfad.open("r", encoding="utf-8-sig") as f:
        r = csv.reader(f)
        for row in r:
            for cell in row:
                if cell.strip():
                    out.append(cell.strip().lower())
    return list(dict.fromkeys(out))


# =========================
# 6) DRIVER
# =========================
def make_driver():
    opts = Options()
    if HEADLESS:
        opts.add_argument("--headless=new")
    opts.add_argument("--no-sandbox")
    opts.add_argument("--disable-dev-shm-usage")
    return webdriver.Chrome(options=opts)


# =========================
# 7) SEARCH
# =========================
def ddg_url(query):
    return "https://duckduckgo.com/?q=" + quote_plus(query) + "&kp=1&ia=web"


def scrape_ddg(driver, url):
    items = []
    driver.get(url)
    pages = 0

    while pages < MAX_DDG_PAGES:
        time.sleep(2)

        results = driver.find_elements(By.CSS_SELECTOR, 'article[data-testid="result"]')

        for r in results:
            try:
                a = r.find_element(By.CSS_SELECTOR, "a[data-testid='result-title-a']")
                link = a.get_attribute("href")
                title = a.text.strip()
            except:
                continue

            snippet = ""
            try:
                snippet = r.find_element(By.CSS_SELECTOR, "div[data-testid='result-snippet']").text.strip()
            except:
                pass

            items.append({
                "url": link,
                "title": title,
                "snippet": snippet
            })

        try:
            more = driver.find_element(By.ID, "more-results")
            driver.execute_script("arguments[0].click();", more)
            pages += 1
            time.sleep(1.5)
        except:
            break

    return items


