# Retrieval (Doc ranking + Chunk ranking)
# =========================
def rank_docs(kb_chunks: List[Tuple[str, str, str, bool, str]], query: str, include_maily: bool) -> List[Tuple[float, str]]:
    """
    Return list of (score, filename) ranked.
    """
    query = clean_ws(query)
    if not query:
        return []

    # group by filename
    doc_text: Dict[str, List[str]] = {}
    for _fp, fname, ch, is_maily, _cid in kb_chunks:
        if (not include_maily) and is_maily:
            continue
        doc_text.setdefault(fname, []).append(ch)

    filenames = list(doc_text.keys())
    texts = ["\n\n".join(doc_text[f])[:60_000] for f in filenames]

    scored: List[Tuple[float, str]] = []

    if TFIDF_VECTORIZER and COSINE_SIM and texts:
        vec = TFIDF_VECTORIZER(min_df=1, ngram_range=(1, 2), max_features=80_000)
        X = vec.fit_transform(texts)
        qv = vec.transform([query])
        sims = COSINE_SIM(qv, X).ravel()
        for fname, sim in zip(filenames, sims):
            score = float(sim) + doc_priority_adjustment(fname)
            scored.append((score, fname))
        scored.sort(key=lambda x: x[0], reverse=True)
        return scored

    q_toks = set(tokenize(query))
    for fname, t in zip(filenames, texts):
        tl = t.lower()
        overlap = sum(1 for tk in q_toks if tk in tl)
        base = overlap / max(1, len(q_toks))
        score = float(base) + doc_priority_adjustment(fname)
        scored.append((score, fname))
    scored.sort(key=lambda x: x[0], reverse=True)
    return scored

def rank_chunks_within_docs(
    kb_chunks: List[Tuple[str, str, str, bool, str]],
    query: str,
    top_doc_filenames: List[str],
    top_k: int
) -> List[Tuple[float, str, str, bool, str]]:
    """
    Returns ranked chunks: (score, filename, chunk_text, is_maily, chunk_id)
    """
    q = clean_ws(query)
    if not q:
        return []
    docset = set(top_doc_filenames)
    pool = [(fname, ch, is_maily, cid) for _fp, fname, ch, is_maily, cid in kb_chunks if fname in docset]
    if not pool:
        return []

    # anchor boost for "which standard" questions
    want_standard = any(k in q.lower() for k in ["which standard", "welche norm", "welchem standard", "gemäß", "in accordance", "according to"])
    anchor_re = re.compile(r"(?i)\b(MBN\s*\d{3,6}|DIN\s*[A-Z0-9\-]+|ISO\s*\d{3,6}|VDA\s*\d+)\b")

    scored = []
    q_toks = set(tokenize(q))
    for fname, ch, is_maily, cid in pool:
        tl = ch.lower()
        overlap = sum(1 for tk in q_toks if tk in tl)
        req_bonus = 2 if re.search(r"(?i)\b(must|shall|required|requirement|muss|soll|erforder|anforder|nachweis|beleg)\b", ch) else 0
        base = overlap + req_bonus
        base += doc_priority_adjustment(fname) * 10.0
        if is_maily:
            base -= 1.0
        if want_standard and anchor_re.search(ch):
            base += 8.0
        scored.append((float(base), fname, ch, is_maily, cid))

    scored.sort(key=lambda x: x[0], reverse=True)
    return scored[:top_k]

def retrieve_best_chunks(kb_chunks, query: str, chunk_top_k: int = 80) -> Tuple[List[Tuple[float, str, str, bool, str]], bool]:
    """
    Two-pass:
    A) docs excluding maily
    B) include maily if A is weak
    Returns (chunks, used_maily_flag)
    """
    # Pass A
    docs_A = rank_docs(kb_chunks, query, include_maily=False)
    top_docs_A = [fname for _s, fname in docs_A[:DOC_TOP_K]]
    chunks_A = rank_chunks_within_docs(kb_chunks, query, top_docs_A, top_k=chunk_top_k)
    if len(chunks_A) >= 6:
        return chunks_A, False

    # Pass B (include maily)
    docs_B = rank_docs(kb_chunks, query, include_maily=True)
    top_docs_B = [fname for _s, fname in docs_B[:max(DOC_TOP_K, 25)]]
    chunks_B = rank_chunks_within_docs(kb_chunks, query, top_docs_B, top_k=max(chunk_top_k, 120))
    return chunks_B, True


# =========================
# “Coverage extraction” (Copilot-like): extract ALL relevant requirement points with citations
# =========================
REQ_CUES = re.compile(
    r"(?i)\b("
    r"must|shall|required|requirement|need to|has to|"
    r"muss|soll|erforderlich|anforder|ist\s+zu|sind\s+zu|"
    r"verpflichtet|ist\s+verpflichtet|sicherzustellen|nachweis|beleg|"
    r"gemäß|in\s+accordance\s+with|according\s+to"
    r")\b"
)

ANCHOR_STD = re.compile(r"(?i)\b(MBN\s*\d{3,6}|DIN\s*[A-Z0-9\-]+|ISO\s*\d{3,6}|VDA\s*\d+)\b")

def sentence_split(text: str) -> List[str]:
    txt = re.sub(r"\s+", " ", text or "").strip()
    if not txt:
        return []
    parts = re.split(r"(?<=[\.\!\?])\s+", txt)
    out = [p.strip(" -•\t\r\n") for p in parts if len(p.strip()) >= 12]
    return out

def extract_points_with_citations(
    ranked_chunks: List[Tuple[float, str, str, bool, str]],
    query: str,
    max_points: int = 12
) -> List[Tuple[str, str]]:
    """
    Returns list of (citation_tag, point_sentence)
      citation_tag like: [file.docx#p12]
    """
    q = clean_ws(query)
    qt = set(tokenize(q))
    want_standard = any(k in q.lower() for k in ["which standard", "welche norm", "welchem standard", "gemäß", "in accordance", "according to"])

    pts: List[Tuple[int, str, str]] = []  # (priority, citation, sentence)
    seen = set()

    for score, fname, ch, is_maily, cid in ranked_chunks[:120]:
        for sent in sentence_split(ch):
            s = clean_ws(sent)
            if not s:
                continue

            # overlap gate (prevents random quoting)
            st = set(tokenize(s))
            overlap = len(qt & st)
            min_ov = 1 if len(qt) <= 6 else 2
            if overlap < min_ov and not want_standard:
                continue

            has_req = bool(REQ_CUES.search(s))
            has_std = bool(ANCHOR_STD.search(s))

            if not (has_req or has_std):
                continue

            key = s.lower()
            if key in seen:
                continue
            seen.add(key)

            pr = overlap
            if want_standard and has_std:
                pr += 50
            if has_std:
                pr += 15
            if has_req:
                pr += 10
            if (not is_maily):
                pr += 3  # prefer real docs
            citation = f"[{cid}]"
            pts.append((pr, citation, s))

    pts.sort(key=lambda x: x[0], reverse=True)

    out: List[Tuple[str, str]] = []
    for pr, cit, s in pts:
        out.append((cit, s))
        if len(out) >= max_points:
            break

    return out


def build_sources_used(ranked_chunks, used_maily: bool, max_sources: int = 10) -> List[str]:
    srcs = []
    for _score, fname, _ch, is_maily, cid in ranked_chunks[:60]:
        if (not used_maily) and fname.lower().startswith(EXCLUDE_AS_SOURCES_PREFIXES):
            continue
        entry = f"{fname} ({cid})"
        if entry not in srcs:
            srcs.append(entry)
        if len(srcs) >= max_sources:
            break
    return srcs


