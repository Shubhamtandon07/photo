def run_bot_once():
    if PRINT_RUN_TIMESTAMP:
        print("\n=== RUN START ===")
        print("Run timestamp:", datetime.now().strftime("%Y-%m-%d %H:%M:%S"))
        print("=================\n")

    time.sleep(STARTUP_DELAY_SEC)

    print("Loading KB docs from:", KB_DIR)
    docs = load_kb_docs(KB_DIR)
    print("KB docs:", len(docs))

    print("Loading MSG archives (style/precedent)...")
    msg_docs = []
    try:
        msg_docs = load_msg_archives(MSG_ARCHIVE_DIRS)
        print("MSG examples loaded:", len(msg_docs))
    except Exception as e:
        print("MSG load skipped (install extract-msg if needed). Reason:", repr(e))

    client = build_azure_client()

    ns, folder, store_name, folder_name = get_target_folder()
    print(f"Mailbox={store_name} | Folder={folder_name}")

    items = folder.Items
    items.Sort("[ReceivedTime]", True)

    drafted = 0
    checked = 0

    your_firstname = safe_firstname_from_email(TARGET_MAILBOX)

    for mail in items:
        checked += 1
        if checked > SCAN_LIMIT:
            break
        if drafted >= PROCESS_PER_RUN:
            break

        try:
            if getattr(mail, "Class", None) != 43:
                continue

            if PROCESSED_CATEGORY.lower() in (mail.Categories or "").lower():
                continue

            if REQUIRE_UNREAD and not mail.UnRead:
                continue

            subject = mail.Subject or ""
            if not strict_subject_ok(subject):
                continue

            sender = get_sender_smtp(mail)
            greeting_name = safe_firstname_from_email(sender)

            body_text = clean_html_to_text(mail.HTMLBody or "")
            question = re.split(r"(?i)\b(von:|from:|gesendet:|sent:|-----original message-----)\b", body_text)[0].strip()
            if not question:
                question = body_text.strip()
            question = clean_question(question)

            # Pass A: non-mail docs
            topA = rank_docs_simple(docs, question, include_maily=False, top_k=TOP_DOCS_PASS_A)

            # Pass B: include a few doc-like mail-chains (AW/RE) as secondary
            mail_candidates = []
            if TOP_DOCS_PASS_B > 0:
                topB = rank_docs_simple(docs, question, include_maily=True, top_k=60)
                mail_candidates = [d for d in topB if d[4] is True][:TOP_DOCS_PASS_B]

            top_docs = topA + mail_candidates

            # Build findings pack (docs only)
            findings, sources = build_requirement_pack(top_docs, question, max_lines=MAX_REQUIREMENT_LINES)
            doc_findings_text = build_findings_text(findings)

            # Build msg precedent pack (optional)
            msg_precedents_text = ""
            if msg_docs:
                msg_precedents_text = build_msg_precedent_pack(msg_docs, question, max_items=10)

            print("\n[PASS] bot mail:", sender)
            print("Question:", question)
            print("Top docs:", [d[2] for d in top_docs])
            print("Doc requirement lines:", len(findings))
            print("Sources:", sources)
            print("Msg precedents chars:", len(msg_precedents_text))

            prompt = build_llm_prompt(
                question=question,
                greeting_name=greeting_name,
                signature_name=your_firstname,
                sources=sources,
                doc_findings_text=doc_findings_text,
                msg_precedents_text=msg_precedents_text,
            )

            reply_text, _resp = call_llm(client, prompt)
            print("LLM reply len:", len(reply_text))
            if DEBUG_PRINT_LLM_PREVIEW:
                print("LLM preview:", repr(reply_text[:220]))

            # Retry with smaller doc findings if empty
            if not reply_text.strip():
                print("WARNING: LLM returned empty. Retrying with smaller Doc Findings Pack...")
                findings2, sources2 = build_requirement_pack(top_docs, question, max_lines=MAX_REQUIREMENT_LINES_RETRY)
                prompt2 = build_llm_prompt(
                    question=question,
                    greeting_name=greeting_name,
                    signature_name=your_firstname,
                    sources=sources2,
                    doc_findings_text=build_findings_text(findings2),
                    msg_precedents_text=msg_precedents_text[:6000],
                )
                reply_text, _resp2 = call_llm(client, prompt2)
                print("LLM retry reply len:", len(reply_text))

            if not reply_text.strip():
                print("WARNING: LLM still empty. Using fallback deterministic email.")
                reply_text = (
                    f"Betreff: Rückfrage\n\n"
                    f"Hallo {greeting_name},\n"
                    f"ich hoffe, es geht Ihnen gut.\n\n"
                    f"Ich konnte aus den aktuell gefundenen Dokumentstellen keine eindeutige Antwort ableiten.\n"
                    f"Können Sie bitte den konkreten Dokumentnamen oder den relevanten Abschnitt nennen?\n\n"
                    f"Mit freundlichen Grüßen\n{your_firstname}\n\n---\n\n"
                    f"Subject: Follow-up question\n\n"
                    f"Hello {greeting_name},\n"
                    f"I hope you are doing well.\n\n"
                    f"I could not derive a clear answer from the currently retrieved document excerpts.\n"
                    f"Could you please point to the specific document name or relevant section?\n\n"
                    f"Best regards,\n{your_firstname}"
                )

            # Create Draft reply
            reply = mail.Reply()

            # Optional image embed
            img_html = ""
            if ALLOW_INLINE_IMAGE:
                img_path = pick_relevant_image(question, IMAGE_DIR)
                if img_path:
                    cid = embed_inline_image(reply, img_path)
                    if cid:
                        img_html = f'<p><img src="cid:{cid}" style="max-width:700px;"></p>'

            html_body = f"<div>{format_outlook_html(reply_text)}{img_html}</div><hr>" + reply.HTMLBody
            reply.HTMLBody = html_body
            reply.Save()

            mark_read(mail)
            add_processed_category(mail)

            drafted += 1
            print("Draft created for:", subject)

            if SELF_NOTIFY:
                send_self_notification(ns, TARGET_MAILBOX, SELF_NOTIFY_TO, subject, sender)

            if CREATE_REMINDER_TASK:
                create_outlook_task_reminder(ns, subject=subject, days=REMINDER_DAYS)

        except Exception as e:
            print("Mail error:", getattr(mail, "Subject", "<no subject>"), "-", repr(e))

    print(f"\nDone. Checked={checked}, Drafted={drafted}")


