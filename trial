def build_msg_precedent_pack(msg_docs: List[Tuple[str, str, str, bool]], question: str, max_items: int = 12) -> str:
    """
    Pulls top matching msg items by token overlap.
    These are NOT authoritative; used for phrasing & precedent if near-identical.
    """
    q_toks = set(tokenize(question))
    scored = []
    for fullpath, fname, text, _is_maily_true in msg_docs:
        tl = text.lower()
        overlap = sum(1 for tk in q_toks if tk in tl)
        if overlap <= 0:
            continue
        scored.append((overlap, fname, text))
    scored.sort(key=lambda x: x[0], reverse=True)

    blocks = []
    for i, (ov, fname, text) in enumerate(scored[:max_items], start=1):
        # keep short
        snip = text
        if len(snip) > 1200:
            snip = snip[:1200] + "…"
        blocks.append(f"[MSG-{i}] {fname}\n{snip}")
    return "\n\n---\n\n".join(blocks).strip()


