import os
from openai import AzureOpenAI

# Put your key here or ensure it's in your environment as OPENAI_API_KEY
# os.environ["OPENAI_API_KEY"] = "PASTE_YOUR_KEY"

KEY = os.getenv("OPENAI_API_KEY") or os.getenv("AZURE_OPENAI_API_KEY")
assert KEY, "Missing OPENAI_API_KEY (or AZURE_OPENAI_API_KEY). Set it first."

API_VERSION = "2024-06-01"

ENDPOINTS = [
    "https://genai-nexus.api.corpinter.net",          # what you shared
    "https://genai-nexus.api.corpinter.net/apikey",   # some orgs require this
]

# You MUST use the DEPLOYMENT NAME configured in Nexus.
# These are guesses—adjust if your org uses a different name.
DEPLOYMENTS = [
    "gpt-5.1",
    "gpt-5.1-chat",
    "gpt-5.1-prod",
    "gpt-5.1-openai",
    "gpt-5.1-codex",   # only if your org created a deployment with this name
]

def try_ping(endpoint, deployment):
    client = AzureOpenAI(
        api_key=KEY,
        azure_endpoint=endpoint,
        api_version=API_VERSION,
    )
    resp = client.chat.completions.create(
        model=deployment,
        messages=[{"role": "user", "content": "Reply with exactly: OK"}],
        temperature=0,
    )
    return resp.choices[0].message.content

last_err = None
for ep in ENDPOINTS:
    for dep in DEPLOYMENTS:
        try:
            out = try_ping(ep, dep)
            print("✅ SUCCESS")
            print("Endpoint:", ep)
            print("Deployment:", dep)
            print("Model output:", out)
            raise SystemExit
        except Exception as e:
            last_err = e
            print(f"❌ fail | endpoint={ep} | deployment={dep} | {type(e).__name__}: {e}")

print("\nNo combination worked. Last error was:\n", repr(last_err))
