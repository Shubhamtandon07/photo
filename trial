def argos_installed_lang_codes() -> set[str]:
    if not ARGOS_TRANSLATE:
        return set()
    try:
        langs = ARGOS_TRANSLATE.get_installed_languages()
        return {getattr(l, "code", "") for l in langs if getattr(l, "code", "")}
    except Exception:
        return set()


def argos_can_translate(src: str, dst: str) -> bool:
    if not ARGOS_TRANSLATE:
        return False
    try:
        langs = ARGOS_TRANSLATE.get_installed_languages()
        src_lang = next((l for l in langs if getattr(l, "code", "") == src), None)
        if not src_lang:
            return False
        return any(getattr(t, "code", "") == dst for t in src_lang.translations)
    except Exception:
        return False


def argos_translate_text(text: str, src: str, dst: str) -> str | None:
    """
    Returns translated text if possible, else None.
    """
    if not text or not ARGOS_TRANSLATE:
        return None
    if not argos_can_translate(src, dst):
        return None
    try:
        langs = ARGOS_TRANSLATE.get_installed_languages()
        src_lang = next((l for l in langs if getattr(l, "code", "") == src), None)
        if not src_lang:
            return None
        translation = next((t for t in src_lang.translations if getattr(t, "code", "") == dst), None)
        if not translation:
            return None
        return translation.translate(text)
    except Exception:
        return None


