from openai import AzureOpenAI
import os, json

# Use the same env var you already set in the notebook:
# os.environ["OPENAI_API_KEY"] = "..."

AZURE_OPENAI_ENDPOINT = "https://genai-nexus.api.corpinter.net"
AZURE_API_VERSION = "2024-06-01"
AZURE_DEPLOYMENT_NAME = "gpt-5.1"

client = AzureOpenAI(
    api_key=os.getenv("OPENAI_API_KEY"),
    azure_endpoint=AZURE_OPENAI_ENDPOINT,
    api_version=AZURE_API_VERSION,
)

resp = client.chat.completions.create(
    model=AZURE_DEPLOYMENT_NAME,
    temperature=0.0,
    max_completion_tokens=80,
    messages=[
        {"role":"system","content":"Reply with exactly OK (no punctuation)."},
        {"role":"user","content":"ping"},
    ],
)

print("=== BASIC SHAPE ===")
print("type(resp):", type(resp))
print("has choices:", hasattr(resp, "choices"))
print("choices len:", len(resp.choices) if hasattr(resp, "choices") else None)

msg = resp.choices[0].message
mc = getattr(msg, "content", None)

print("\n=== message.content ===")
print("type(message.content):", type(mc))
print("message.content repr:", repr(mc)[:400])

# If content is list of parts, print each part
if isinstance(mc, list):
    print("\n=== content parts ===")
    for i, p in enumerate(mc, start=1):
        print(f"part[{i}] type:", type(p))
        if isinstance(p, dict):
            print("  keys:", list(p.keys()))
            print("  text:", repr(p.get("text"))[:300])
            print("  content:", repr(p.get("content"))[:300])
        else:
            print("  attrs:", [a for a in ["type","text","content","output_text","value"] if hasattr(p, a)])
            for a in ["type","text","content","output_text","value"]:
                if hasattr(p, a):
                    print(f"  {a}:", repr(getattr(p,a))[:300])

print("\n=== model_dump top keys ===")
d = resp.model_dump()
print(list(d.keys()))
print("dump preview:", json.dumps(d, ensure_ascii=False)[:800])
