def run_bot_once():
    time.sleep(STARTUP_DELAY_SEC)

    print("Building KB index from:", KB_DIR)
    kb_chunks = build_kb_index(KB_DIR)
    print("KB chunks:", len(kb_chunks))

    client = build_azure_client()

    ns, folder, store_name, folder_name = get_target_folder()
    print(f"Mailbox={store_name} | Folder={folder_name}")

    items = folder.Items
    items.Sort("[ReceivedTime]", True)

    drafted = 0
    checked = 0

    signature_name = safe_firstname_from_email(TARGET_MAILBOX)

    for mail in items:
        checked += 1
        if checked > SCAN_LIMIT:
            break
        if drafted >= PROCESS_PER_RUN:
            break

        try:
            if getattr(mail, "Class", None) != 43:
                continue

            if PROCESSED_CATEGORY.lower() in (mail.Categories or "").lower():
                continue

            if REQUIRE_UNREAD and not mail.UnRead:
                continue

            subject = mail.Subject or ""
            if not strict_subject_ok(subject):
                continue

            sender = get_sender_smtp(mail)
            greeting_name = safe_firstname_from_email(sender)

            body_text = clean_html_to_text(mail.HTMLBody or "")

            # keep only the top part (strip quoted chain)
            question = re.split(
                r"(?i)\b(von:|from:|gesendet:|sent:|-----original message-----)\b",
                body_text
            )[0].strip()
            if not question:
                question = body_text.strip()

            # Retrieval (two-pass)
            evidence_chunks, used_mail_docs = retrieve_evidence(kb_chunks, question)

            # Extract ALL key requirement points
            extracted = extract_requirements(evidence_chunks, query=question, max_total=10)
            extraction_pack = build_extraction_pack(extracted)

            # If extractor found nothing, still provide raw evidence blocks (grounded)
            if extraction_pack.strip() == "(no extracted requirements)":
                raw_lines = ["## Evidence (no explicit requirement sentences detected)"]
                for i, c in enumerate(evidence_chunks[:12], start=1):
                    snippet = clean_ws(c.text)
                    if len(snippet) > 650:
                        snippet = snippet[:650] + "…"
                    raw_lines.append(f"- ({c.chunk_id}) {snippet}")
                extraction_pack = "\n".join(raw_lines)

            srcs = sources_used(evidence_chunks, used_mail_docs=used_mail_docs)

            # Debug (optional)
            print("PASS:", subject, "| q chars:", len(question), "| evidence:", len(evidence_chunks), "| extracted:", len(extracted))

            prompt = build_llm_prompt(
                question=question,
                greeting_name=greeting_name,
                signature_name=signature_name,
                extraction_pack=extraction_pack,
                sources=srcs,
                used_mail_docs=used_mail_docs
            )

            reply_text = ""
            try:
                reply_text = call_llm(client, prompt)
            except Exception as e_llm:
                print("LLM error:", repr(e_llm))

            reply_text = safe_nonempty(reply_text)

            # If model returned empty, fallback (never empty draft)
            if not reply_text:
                reply_text = build_fallback_reply(greeting_name, signature_name, question, srcs)

            # Final redaction pass
            reply_text = redact_remove(reply_text)

            html = format_outlook_html(reply_text)
            if not html.strip() or html.strip() == "<p></p>":
                html = format_outlook_html(build_fallback_reply(greeting_name, signature_name, question, srcs))

            # Create draft reply
            reply = mail.Reply()
            reply.HTMLBody = f"<div>{html}</div><hr>" + reply.HTMLBody
            reply.Save()

            # Mark original as processed
            mark_read(mail)
            add_processed_category(mail)

            drafted += 1
            print("Draft created for:", subject)

            if SELF_NOTIFY:
                try:
                    send_self_notification(ns, TARGET_MAILBOX, SELF_NOTIFY_TO, subject, sender)
                except Exception as e:
                    print("Self notify failed:", repr(e))

            if CREATE_REMINDER_TASK:
                create_outlook_task_reminder(ns, subject=subject, days=REMINDER_DAYS)

        except Exception as e:
            print("Mail error:", getattr(mail, "Subject", "<no subject>"), "-", repr(e))

    print(f"Done. Checked={checked}, Drafted={drafted}")


