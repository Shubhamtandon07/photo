# === Nexus GPT-5.1 quick health check (Notebook-safe) ===
# Run this cell first. It verifies:
# 1) OPENAI_API_KEY is present
# 2) Endpoint + deployment works (expects exactly "OK")
# 3) Prints response shape + finish_reason + content (so you see if empty)

import os, json
from openai import AzureOpenAI

AZURE_OPENAI_ENDPOINT = "https://genai-nexus.api.corpinter.net"   # no /apikey/
AZURE_API_VERSION = "2024-06-01"
AZURE_DEPLOYMENT_NAME = "gpt-5.1"

key = os.getenv("OPENAI_API_KEY", "")
print("OPENAI_API_KEY present:", bool(key), "len:", len(key))

client = AzureOpenAI(
    api_key=key,
    azure_endpoint=AZURE_OPENAI_ENDPOINT,
    api_version=AZURE_API_VERSION,
)

resp = client.chat.completions.create(
    model=AZURE_DEPLOYMENT_NAME,
    temperature=0.0,
    max_completion_tokens=30,
    messages=[
        {"role": "system", "content": "Reply with exactly: OK"},
        {"role": "user", "content": "ping"},
    ],
)

print("\n=== RESPONSE META ===")
print("type(resp):", type(resp))
print("choices:", len(resp.choices) if hasattr(resp, "choices") else None)
try:
    print("finish_reason:", getattr(resp.choices[0], "finish_reason", None))
except Exception as e:
    print("finish_reason: <err>", repr(e))

print("\n=== CONTENT ===")
try:
    content = resp.choices[0].message.content
    print("message.content type:", type(content))
    print("message.content:", repr(content))
except Exception as e:
    print("content read error:", repr(e))

print("\n=== DUMP (first 1200 chars) ===")
try:
    d = resp.model_dump()
    print(json.dumps(d, ensure_ascii=False)[:1200])
except Exception as e:
    print("model_dump error:", repr(e))
