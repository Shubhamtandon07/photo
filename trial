def clean_ws(s: str) -> str:
    return re.sub(r"\s+", " ", s or "").strip()

def strict_subject_ok(subject: str) -> bool:
    return (subject or "").strip().casefold() == STRICT_SUBJECT.casefold()

def clean_html_to_text(html: str) -> str:
    txt = re.sub(r"<[^>]+>", " ", html or "", flags=re.S)
    return clean_ws(txt)

def safe_firstname_from_email(email: str) -> str:
    email = (email or "").strip()
    local = email.split("@", 1)[0] if "@" in email else email
    first = local.split(".", 1)[0].strip()
    return (first[:1].upper() + first[1:]) if first else "Colleague"

def format_outlook_html(text: str) -> str:
    """
    Plain -> Outlook HTML.
    Bullets: lines starting with "- ".
    """
    text = (text or "").replace("\r\n", "\n").strip()
    if not text:
        return "<p></p>"

    blocks = re.split(r"\n\s*\n", text)
    out = []
    for block in blocks:
        lines = [ln.rstrip() for ln in block.split("\n") if ln.strip()]
        if not lines:
            continue
        if all(ln.lstrip().startswith("- ") for ln in lines):
            out.append("<ul>")
            for ln in lines:
                out.append(f"<li>{escape(ln.lstrip()[2:].strip())}</li>")
            out.append("</ul>")
        else:
            out.append("<p>" + "<br>".join(escape(ln.strip()) for ln in lines) + "</p>")
    return "\n".join(out)

def tokenize(s: str) -> List[str]:
    toks = re.split(r"[^a-zA-Z0-9ÃÃÃÃĪÃķÃžÃ]+", (s or "").lower())
    return [t for t in toks if t and t not in STOPWORDS and len(t) >= 3]

def is_maily_filename(name: str) -> bool:
    n = (name or "").lower()
    stem = Path(n).stem.lower()
    if stem.startswith("~$"):
        return True
    if stem.startswith(MAILY_PREFIXES):
        return True
    return any(h in n for h in MAILY_HINTS)

def doc_priority_adjustment(filename: str) -> float:
    """
    Higher is better.
    Strongly demote AW_/RE_/FW_/WG_ and mail-ish docs.
    """
    fn = (filename or "").lower()
    score = 0.0
    if fn.startswith(MAILY_PREFIXES):
        score -= 0.70
    if any(h in fn for h in MAILY_HINTS):
        score -= 0.30
    # small boost to authoritative words
    if re.search(r"(?i)\b(mbn|din|iso|vda|standard|policy|guideline|kapitel|chapter|requirements|norm)\b", fn):
        score += 0.25
    return score

