SOCIAL_BAD = [
    "facebook.com","instagram.com","tiktok.com",
    "twitter.com","x.com","reddit.com"
]

BAD_PATH = [
    "/jobs","/careers","/investor","/finance",
]

def bad_domain(d):
    return any(x in d for x in SOCIAL_BAD)

def bad_path(u):
    return any(x in u.lower() for x in BAD_PATH)


# =========================
# 9) QUERY BUILDER
# =========================
def build_queries(domain, material):
    base = [
        "human rights violation",
        "forced labor",
        "child labor",
        "environmental damage",
        "pollution",
        "lawsuit",
        "allegations"
    ]

    queries = []

    for term in base:
        queries.append(f"site:{domain} {material} {term}")

    queries.append(f"site:{domain} {material}")

    return queries[:QUERIES_PER_SITE]


