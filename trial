def build_openai_client():
    """
    Build a client for Nexus. Tries several base_url candidates.
    """
    key = os.getenv(OPENAI_API_KEY_ENV, "").strip()
    if not key:
        raise SystemExit(f"Missing {OPENAI_API_KEY_ENV}. Set it in your environment.")

    try:
        from openai import OpenAI  # type: ignore
    except Exception as e:
        raise SystemExit("Missing dependency: openai. Install: python -m pip install -U openai") from e

    last_err = None
    for base_url in NEXUS_BASE_URL_CANDIDATES:
        try:
            client = OpenAI(api_key=key, base_url=base_url)
            # tiny smoke call (no cost heavy): if it fails, we'll try next
            _ = client.responses.create(model=LLM_MODEL, input="OK", max_output_tokens=5)
            return client, base_url
        except Exception as e:
            last_err = e
            continue

    raise SystemExit(f"Could not authenticate to Nexus with tried base_url candidates. Last error: {repr(last_err)}")

def build_llm_prompt(question: str, greeting_name: str, signature_name: str, evidence: List[Chunk]) -> str:
    """
    The LLM MUST:
    - answer using only evidence
    - write clean email DE + EN
    - no personal/supplier names etc
    - include short sources list at end (doc titles only + paragraph ids)
    """
    # redact evidence before sending to LLM (avoid leaking names, emails etc)
    ev_blocks = []
    for i, c in enumerate(evidence[:24], start=1):
        txt = redact_remove(c.text)
        # keep short per block
        txt = txt[:900]
        ev_blocks.append(f"[{i}] SOURCE: {c.chunk_id}\n{txt}")

    ev_text = "\n\n---\n\n".join(ev_blocks) if ev_blocks else "(no evidence)"

    # also redact the question before LLM
    q_red = redact_remove(question)

    return f"""
You are writing a professional email reply. You MUST follow these rules:

GROUNDING / SAFETY RULES (strict):
1) Use ONLY the EVIDENCE blocks below to answer. Do NOT use outside knowledge.
2) If the evidence does not contain the answer, say you could not find it and ask 1 short clarification question.
3) Do NOT include personal names, supplier names, email addresses, phone numbers, IDs, references, addresses, or IBANs.
4) Do NOT quote long passages; paraphrase concisely.
5) Write BOTH languages fully: German first, then a separator line '---', then English.
6) Use paragraphs. If listing items, use bullets starting with "- ".

CONTENT RULES:
- Start DE with: "Hallo {greeting_name},"
- End DE with: "Mit freundlichen Grüßen" + "{signature_name}"
- Start EN with: "Hello {greeting_name},"
- End EN with: "Best regards," + "{signature_name}"
- At the very end add:
  "Sources used: <comma-separated doc titles with chunk ids>"
  Use only filenames + #pX from SOURCE labels. Do not include email chains unless they were needed.

QUESTION:
{q_red}

EVIDENCE:
{ev_text}
""".strip()

def llm_generate_reply(client, prompt: str) -> str:
    # Use Responses API (new SDK). Keep it deterministic.
    resp = client.responses.create(
        model=LLM_MODEL,
        input=prompt,
        temperature=0.1,
        max_output_tokens=800,
    )
    out = (resp.output_text or "").strip()
    return out

