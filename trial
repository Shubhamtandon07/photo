def is_maily_filename(filename: str) -> bool:
    n = (filename or "").lower()
    stem = Path(n).stem.lower()
    if stem.startswith("~$"):
        return True
    if stem.startswith(MAILY_PREFIXES):
        return True
    return any(h in n for h in MAILY_HINTS)

@dataclass
class Chunk:
    fullpath: str
    filename: str
    chunk_id: str        # filename#pX
    text: str
    is_maily: bool

def split_into_chunks(text: str) -> List[str]:
    text = text or ""
    # normalize common docx-table artifacts
    text = re.sub(r"[|]{2,}", "|", text)
    # paragraph split
    paras = [p.strip() for p in re.split(r"\n{2,}", text) if p.strip()]
    chunks: List[str] = []
    for p in paras:
        if looks_like_table_noise(p):
            p = normalize_tableish_line(p)
        if len(p) <= MAX_CHARS_PER_CHUNK:
            chunks.append(p)
        else:
            for i in range(0, len(p), MAX_CHARS_PER_CHUNK):
                chunks.append(p[i:i + MAX_CHARS_PER_CHUNK])
        if len(chunks) >= MAX_CHUNKS_PER_DOC:
            break
    return chunks

def build_kb_index(kb_dir: str) -> List[Chunk]:
    base = Path(kb_dir)
    if not base.exists() or not base.is_dir():
        raise SystemExit(f"KB_DIR not found: {kb_dir}")

    files = [p for p in base.rglob("*") if p.is_file() and p.suffix.lower() in SUPPORTED_EXTS]
    files = files[:MAX_DOCS]

    chunks: List[Chunk] = []
    for p in sorted(files):
        try:
            txt = extract_text_from_file(p)
            txt = (txt or "").strip()
            if not txt:
                continue
            txt = txt[:MAX_CHARS_PER_DOC]
            maily = is_maily_filename(p.name)
            parts = split_into_chunks(txt)
            for i, ch in enumerate(parts, start=1):
                if not ch.strip():
                    continue
                cid = f"{p.name}#p{i}"
                chunks.append(Chunk(str(p), p.name, cid, ch, maily))
        except Exception:
            continue
    return chunks


# =========================================================
# RETRIEVAL (doc->chunk) with two-pass
# =========================================================
def doc_priority_adjustment(filename: str) -> float:
    fn = (filename or "").lower()
    score = 0.0

    # heavy demotion for mail-chains
    if fn.startswith(MAILY_PREFIXES):
        score -= 0.60
    if any(h in fn for h in MAILY_HINTS):
        score -= 0.25

    # boost authoritative signals
    if re.search(r"(?i)\b(mbn|din|iso|vda|standard|policy|guideline|kapitel|chapter|requirements|norm)\b", fn):
        score += 0.20

    return score

def rank_docs(chunks: List[Chunk], query: str, include_maily: bool) -> List[Tuple[float, str, str]]:
    query = clean_ws(query)
    if not query:
        return []

    doc_map: Dict[Tuple[str, str], List[str]] = {}
    for c in chunks:
        if not include_maily and c.is_maily:
            continue
        doc_map.setdefault((c.fullpath, c.filename), []).append(c.text)

    docs = list(doc_map.keys())
    texts = ["\n\n".join(doc_map[d])[:60_000] for d in docs]

    scored: List[Tuple[float, str, str]] = []

    if TFIDF_VECTORIZER and COSINE_SIM and texts:
        vec = TFIDF_VECTORIZER(min_df=1, ngram_range=(1, 2), max_features=80_000)
        X = vec.fit_transform(texts)
        qv = vec.transform([query])
        sims = COSINE_SIM(qv, X).ravel()
        for (fullpath, fname), sim in zip(docs, sims):
            score = float(sim) + doc_priority_adjustment(fname)
            scored.append((score, fullpath, fname))
        scored.sort(key=lambda x: x[0], reverse=True)
        return scored

    # fallback overlap
    q_toks = set(tokenize(query))
    for (fullpath, fname), t in zip(docs, texts):
        tl = t.lower()
        overlap = sum(1 for tk in q_toks if tk in tl)
        base = overlap / max(1, len(q_toks))
        score = float(base) + doc_priority_adjustment(fname)
        scored.append((score, fullpath, fname))
    scored.sort(key=lambda x: x[0], reverse=True)
    return scored

def rank_chunks(chunks: List[Chunk], query: str, top_docs: List[Tuple[float, str, str]], top_k: int) -> List[Tuple[float, Chunk]]:
    query = clean_ws(query)
    if not query:
        return []

    doc_set = set((fp, fn) for _, fp, fn in top_docs)
    pool = [c for c in chunks if (c.fullpath, c.filename) in doc_set]
    if not pool:
        return []

    if TFIDF_VECTORIZER and COSINE_SIM:
        vec = TFIDF_VECTORIZER(min_df=1, ngram_range=(1, 2), max_features=90_000)
        X = vec.fit_transform([c.text for c in pool])
        qv = vec.transform([query])
        sims = COSINE_SIM(qv, X).ravel()
        doc_score_map = {(fp, fn): ds for ds, fp, fn in top_docs}
        scored = []
        for c, sim in zip(pool, sims):
            score = float(sim) + doc_score_map.get((c.fullpath, c.filename), 0.0) * 0.10
            scored.append((score, c))
        scored.sort(key=lambda x: x[0], reverse=True)
        return scored[:top_k]

    q_toks = set(tokenize(query))
    doc_score_map = {(fp, fn): ds for ds, fp, fn in top_docs}
    scored = []
    for c in pool:
        tl = c.text.lower()
        overlap = sum(1 for tk in q_toks if tk in tl)
        score = overlap + doc_score_map.get((c.fullpath, c.filename), 0.0) * 0.10
        scored.append((float(score), c))
    scored.sort(key=lambda x: x[0], reverse=True)
    return scored[:top_k]

def retrieve_evidence(all_chunks: List[Chunk], question: str) -> Tuple[List[Chunk], bool]:
    """
    Returns (selected_chunks, used_mail_docs_flag)
    """
    q = clean_ws(question)
    if not q:
        return [], False

    # Pass A: non-mail docs only
    if PASS_A_REQUIRE_NON_MAIL:
        docs_A = rank_docs(all_chunks, q, include_maily=False)
        top_docs_A = docs_A[:DOC_TOP_K]
        chunks_A = rank_chunks(all_chunks, q, top_docs_A, top_k=CHUNK_TOP_K)
        selected_A = [c for _, c in chunks_A]
        if selected_A:
            return selected_A, False

    # Pass B: allow mail docs (still penalized)
    if ENABLE_PASS_B_INCLUDE_MAIL:
        docs_B = rank_docs(all_chunks, q, include_maily=True)
        top_docs_B = docs_B[:max(DOC_TOP_K, 25)]
        chunks_B = rank_chunks(all_chunks, q, top_docs_B, top_k=max(CHUNK_TOP_K, 100))
        selected_B = [c for _, c in chunks_B]
        if selected_B:
            return selected_B, True

    return [], False


# =========================================================
# REQUIREMENT EXTRACTION (so you get all key points, not just 1–2)
# =========================================================
REQ_CUES = re.compile(
    r"(?i)\b("
    r"must|shall|required|requirement|need to|has to|"
    r"muss|soll|erforderlich|Anforderung(en)?|ist\s+zu|sind\s+zu|"
    r"hat\s+.*\s+zu|hat\s+sicherzustellen|verpflichtet\s+sich|"
    r"ist\s+verpflichtet|müssen|sicherzustellen|nachweis|beleg|"
    r"in\s+accordance\s+with|gemäß|in\s+Übereinstimmung\s+mit"
    r")\b"
)

STANDARD_ANCHOR = re.compile(r"(?i)\b(MBN\s*\d{3,6}|DIN\s*[A-Z0-9\-]+|ISO\s*\d{3,6}|VDA\s*\d+)\b")

def sentence_split(text: str) -> List[str]:
    txt = re.sub(r"\s+", " ", text or "").strip()
    if not txt:
        return []
    parts = re.split(r"(?<=[\.\!\?])\s+", txt)
    out = [p.strip(" -•\t\r\n") for p in parts if len(p.strip()) >= 12]
    return out

def extract_requirements(chunks: List[Chunk], query: str, max_total: int = 10) -> List[Tuple[str, str]]:
    """
    Returns list of (chunk_id, sentence).
    Tries to capture ALL relevant requirement sentences, deduped.
    Special handling:
      - “which standard” questions: prefer sentences containing MBN/DIN/ISO/VDA anchors.
    """
    q = query.lower()
    want_standard = any(k in q for k in ["which standard", "welche norm", "welchem standard", "gemäß", "according to", "in accordance"])

    candidates: List[Tuple[int, str, str]] = []  # (priority, chunk_id, sentence)
    seen = set()

    for c in chunks[:60]:
        for sent in sentence_split(c.text):
            s = sent.strip()
            if not s:
                continue

            # reduce tableish repetitions
            if "|" in s and looks_like_table_noise(s):
                s = normalize_tableish_line(s)

            key = s.lower()
            if key in seen:
                continue

            # base filter: overlap with query tokens (keeps on-topic)
            qt = set(tokenize(query))
            st = set(tokenize(s))
            overlap = len(qt & st)

            # if query is short, allow lower overlap
            min_ov = 1 if len(qt) <= 6 else 2
            if overlap < min_ov and not want_standard:
                continue

            # requirement cue
            if REQ_CUES.search(s) or STANDARD_ANCHOR.search(s):
                pr = 0
                if want_standard and STANDARD_ANCHOR.search(s):
                    pr += 50
                if STANDARD_ANCHOR.search(s):
                    pr += 15
                if REQ_CUES.search(s):
                    pr += 10
                pr += overlap

                candidates.append((pr, c.chunk_id, s))
                seen.add(key)

    # sort best-first
    candidates.sort(key=lambda x: x[0], reverse=True)

    # keep up to max_total
    out: List[Tuple[str, str]] = []
    for pr, cid, s in candidates:
        out.append((cid, s))
        if len(out) >= max_total:
            break

    return out

def build_extraction_pack(extracted: List[Tuple[str, str]]) -> str:
    if not extracted:
        return "(no extracted requirements)"
    lines = ["## Extracted requirement points (grounded)"]
    for cid, s in extracted:
        lines.append(f"- ({cid}) {s}")
    return "\n".join(lines)

def sources_used(chunks: List[Chunk], used_mail_docs: bool) -> List[str]:
    """
    Return unique sources; exclude AW/RE unless pass B used them (or they were truly needed).
    """
    srcs = []
    for c in chunks[:30]:
        fn = c.filename
        if (not used_mail_docs) and fn.lower().startswith(EXCLUDE_AS_SOURCES_PREFIXES):
            continue
        entry = f"{fn} ({c.chunk_id})"
        if entry not in srcs:
            srcs.append(entry)
    return srcs[:10]


