def read_txt(p: Path) -> str:
    return p.read_text(encoding="utf-8", errors="ignore")


def read_docx(p: Path) -> str:
    try:
        from docx import Document as DocxDocument  # type: ignore
    except Exception:
        return ""
    doc = DocxDocument(str(p))
    paras = "\n".join(clean_ws(par.text) for par in doc.paragraphs if clean_ws(par.text))

    # table rows as "A | B | C"
    table_lines = []
    for t in doc.tables:
        for row in t.rows:
            cells = [clean_ws(c.text) for c in row.cells]
            if any(cells):
                table_lines.append(" | ".join(cells))
    return (paras + "\n" + "\n".join(table_lines)).strip()


def read_pdf(p: Path) -> str:
    try:
        import pdfplumber  # type: ignore
        out = []
        with pdfplumber.open(str(p)) as pdf:
            for page in pdf.pages:
                out.append(page.extract_text() or "")
        return "\n".join(out).strip()
    except Exception:
        pass

    try:
        from pypdf import PdfReader  # type: ignore
        r = PdfReader(str(p))
        out = []
        for pg in r.pages:
            try:
                out.append(pg.extract_text() or "")
            except Exception:
                pass
        return "\n".join(out).strip()
    except Exception:
        return ""


def read_xlsx(p: Path) -> str:
    try:
        import openpyxl  # type: ignore
    except Exception:
        return ""
    wb = openpyxl.load_workbook(str(p), data_only=True, read_only=True)
    out = []
    for ws in wb.worksheets:
        out.append(f"Sheet: {ws.title}")
        max_rows = min(ws.max_row or 0, 200)
        max_cols = min(ws.max_column or 0, 40)
        for r in range(1, max_rows + 1):
            row_vals = []
            for c in range(1, max_cols + 1):
                v = ws.cell(row=r, column=c).value
                row_vals.append("" if v is None else str(v))
            if any(x.strip() for x in row_vals):
                out.append(" | ".join(clean_ws(x) for x in row_vals))
    return "\n".join(out).strip()


def extract_text_from_file(p: Path) -> str:
    ext = p.suffix.lower()
    if ext == ".txt":
        return read_txt(p)
    if ext == ".docx":
        return read_docx(p)
    if ext == ".pdf":
        return read_pdf(p)
    if ext == ".xlsx":
        return read_xlsx(p)
    return ""


def is_maily_filename(p: Path) -> bool:
    name = (p.name or "").lower()
    stem = (p.stem or "").lower()
    if stem.startswith("~$"):
        return True
    if stem.startswith(MAILY_PREFIXES):
        return True
    if any(h in name for h in MAILY_HINTS):
        return True
    return False


# =========================
# BUILD KB INDEX (docs -> chunks)
# =========================
def split_into_chunks(text: str) -> List[str]:
    text = text or ""

    # normalize "table garbage" a bit:
    # collapse repeated pipes and repeated spaces
    text = re.sub(r"[|]{2,}", "|", text)
    text = re.sub(r"[ \t]{2,}", " ", text)

    paras = [p.strip() for p in re.split(r"\n{2,}", text) if p.strip()]
    chunks: List[str] = []
    for p in paras:
        if len(p) <= MAX_CHARS_PER_CHUNK:
            chunks.append(p)
        else:
            for i in range(0, len(p), MAX_CHARS_PER_CHUNK):
                chunks.append(p[i:i + MAX_CHARS_PER_CHUNK])
        if len(chunks) >= MAX_CHUNKS_PER_DOC:
            break
    return chunks


def doc_priority_adjustment(filename: str) -> float:
    """
    Higher is better.
    Real docs boosted; AW_/RE_/FW_/WG_ strongly penalized but not excluded.
    """
    fn = (filename or "").lower()
    score = 0.0
    if fn.startswith(MAILY_PREFIXES):
        score -= 0.70
    if any(h in fn for h in MAILY_HINTS):
        score -= 0.25
    # boost authoritative keywords
    if re.search(r"(?i)\b(mbn|din|iso|vda|standard|policy|guideline|kapitel|chapter|requirements|norm)\b", fn):
        score += 0.25
    return score


def build_kb_index(kb_dir: str) -> List[Tuple[str, str, str, bool]]:
    """
    Returns list of chunks:
      (source_file_fullpath, source_filename, chunk_text, is_maily)
    """
    base = Path(kb_dir)
    if not base.exists() or not base.is_dir():
        raise SystemExit(f"KB_DIR not found: {kb_dir}")

    files = [p for p in base.rglob("*") if p.is_file() and p.suffix.lower() in SUPPORTED_EXTS]
    files = files[:MAX_DOCS]

    chunks: List[Tuple[str, str, str, bool]] = []
    for p in sorted(files):
        try:
            txt = extract_text_from_file(p)
            txt = (txt or "").strip()
            if not txt:
                continue
            txt = txt[:MAX_CHARS_PER_DOC]
            maily = is_maily_filename(p)

            for ch in split_into_chunks(txt):
                if ch.strip():
                    chunks.append((str(p), p.name, ch, maily))
        except Exception:
            continue
    return chunks


# =========================
# RETRIEVAL (two-pass merge)
# =========================
def score_chunk(query: str, chunk_text: str, filename: str, is_maily: bool) -> float:
    q_toks = tokenize(query)
    if not q_toks:
        return 0.0

    t = chunk_text.lower()
    overlap = 0
    for tk in set(q_toks):
        if tk in t:
            overlap += 1

    # bonus for requirements/standards language
    req_bonus = 0
    if re.search(r"(?i)\b(must|shall|required|requirement|muss|soll|erforder|anforder|nachweis|beleg|standard|norm|gemäß|in accordance)\b", chunk_text):
        req_bonus = 2

    base = overlap + req_bonus
    base += doc_priority_adjustment(filename) * 10.0

    # chunk-level demotion for mail-chains
    if is_maily:
        base -= 1.0

    return float(base)


def pick_best_chunks_two_pass(kb_chunks: List[Tuple[str, str, str, bool]], query: str, top_k: int = 20):
    """
    Pass A: prefer non-maily docs
    Pass B: include maily docs (AW/RE) to catch identical past Q&A and MB phrasing
    Merge and rerank.
    """
    scored_A = []
    scored_B = []

    for fullpath, fname, ch, is_maily in kb_chunks:
        s = score_chunk(query, ch, fname, is_maily)
        if s <= 0:
            continue
        if is_maily:
            scored_B.append((s, fullpath, fname, ch, is_maily))
        else:
            scored_A.append((s, fullpath, fname, ch, is_maily))

    scored_A.sort(key=lambda x: x[0], reverse=True)
    scored_B.sort(key=lambda x: x[0], reverse=True)

    # take more from A, fewer from B
    take_A = min(len(scored_A), max(14, top_k))
    take_B = min(len(scored_B), max(6, top_k // 2))

    merged = scored_A[:take_A] + scored_B[:take_B]
    merged.sort(key=lambda x: x[0], reverse=True)

    return merged[:top_k]


# =========================
# KEY FINDINGS EXTRACTION (the critical Copilot-style fix)
# =========================
def split_sentences_loose(text: str) -> List[str]:
    """
    Splits normal sentences AND also breaks common docx-table rows.
    Prevents garbage like 'A | B | C | ...' from being treated as one unit.
    """
    text = re.sub(r"\s+", " ", text or "").strip()
    if not text:
        return []
    parts = re.split(r"(?<=[\.\!\?])\s+| \| ", text)
    out = [p.strip(" -•\t\r\n") for p in parts if len(p.strip()) >= 12]
    return out


def extract_key_findings(best_chunks, question: str, max_findings: int = 10):
    """
    Extract the best "answer candidate" lines BEFORE the LLM sees them.
    """
    ql = (question or "").lower()

    env_terms = [
        "umwelt", "environment", "co2", "co₂", "rezyklat", "sekundär", "secondary material",
        "grünstrom", "renewable", "scope", "sop", "2039", "energie", "emission"
    ]
    standard_terms = ["mbn", "din", "iso", "vda", "gemäß", "in accordance", "standard", "norm"]

    want_env = any(t in ql for t in ["umwelt", "environment", "co2", "co₂", "rezyklat", "sekundär", "grünstrom"])
    want_standard = any(t in ql for t in ["welch", "which", "gemäß", "in accordance", "standard", "norm"])

    q_tokens = set(tokenize(question))
    findings = []
    seen = set()

    for score, fullpath, fname, ch, is_maily in best_chunks:
        for sent in split_sentences_loose(ch):
            s_low = sent.lower()

            anchor_hit = 0
            if want_env:
                anchor_hit += sum(1 for t in env_terms if t in s_low)
            if want_standard:
                anchor_hit += sum(1 for t in standard_terms if t in s_low)

            token_hit = len(q_tokens & set(tokenize(sent)))

            # require some signal
            if anchor_hit == 0 and token_hit == 0:
                continue

            sscore = anchor_hit * 5 + token_hit
            key = (fname.lower(), sent.lower())
            if key in seen:
                continue
            seen.add(key)

            findings.append((sscore, fname, sent, is_maily))

    findings.sort(key=lambda x: x[0], reverse=True)

    picked = []
    for sscore, fname, sent, is_maily in findings:
        picked.append((fname, sent, is_maily))
        if len(picked) >= max_findings:
            break

    return picked


def sources_from_findings(findings) -> List[str]:
    """
    Human sources list: up to 6 real docs only (no AW_/RE_ in list).
    """
    srcs = []
    for fname, _sent, _is_maily in findings:
        if fname.lower().startswith(EXCLUDE_AS_SOURCES_PREFIXES):
            continue
        if fname not in srcs:
            srcs.append(fname)
    return srcs[:6]


def build_findings_block(findings) -> str:
    """
    Compact LLM evidence format.
    """
    lines = []
    for i, (fname, sent, is_maily) in enumerate(findings, start=1):
        tag = "MAIL-CHAIN" if is_maily else "DOC"
        lines.append(f"[{i}] ({tag}) {fname}: {sent}")
    return "\n".join(lines)


