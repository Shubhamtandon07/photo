import sys, subprocess

print("Python:", sys.version)
print("Executable:", sys.executable)

p = subprocess.run(["py", "--version"], capture_output=True, text=True)
print("py --version:", p.stdout.strip() or p.stderr.strip())

p = subprocess.run(["py", "-m", "pip", "--version"], capture_output=True, text=True)
print("pip:", p.stdout.strip() or p.stderr.strip())
