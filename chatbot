# =========================
# UTIL
# =========================
def clean_ws(s: str) -> str:
    return re.sub(r"\s+", " ", s or "").strip()

def now_stamp() -> str:
    return datetime.now().strftime("%Y%m%d_%H%M%S")

# =========================
# JAILBREAK / FILTER HARDENING (FIXED REGEX)
# =========================
JAILBREAK_PATTERNS = [
    r"\bignore (all|any|previous) instructions\b",
    r"\bdisregard (all|any|previous) instructions\b",
    r"\b(system prompt|developer message|hidden prompt)\b",
    r"\byou are (now )?(chatgpt|an ai|a language model)\b",
    r"\bact as\b",
    r"\bjailbreak\b",
    r"\bdo anything now\b",
    r"\bdan\b",
    r"\brole\s*:\s*(system|developer)\b",
]
JAILBREAK_RE = re.compile("|".join(JAILBREAK_PATTERNS), flags=re.IGNORECASE)

# Hard PII patterns to redact (we keep it basic)
EMAIL_RE = re.compile(r"\b[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}\b", re.I)
PHONE_RE = re.compile(r"(?:(?:\+|00)\d{1,3}[\s\-]?)?(?:\(?\d{2,5}\)?[\s\-]?)?\d[\d\s\-]{6,}\d")
URL_RE = re.compile(r"\bhttps?://[^\s<>()]+\b", re.I)
IBAN_RE = re.compile(r"\b[A-Z]{2}\d{2}[A-Z0-9]{11,30}\b", re.I)

def sanitize_for_llm(text: str) -> str:
    """
    Reduce content-filter triggers + remove obvious PII.
    Important: do NOT insert phrases like "ignore previous instructions" in the prompt itself.
    """
    if not text:
        return ""

    # Remove lines containing jailbreak-like phrases
    lines = text.splitlines()
    kept = []
    for ln in lines:
        if JAILBREAK_RE.search(ln):
            continue
        kept.append(ln)
    t = "\n".join(kept)

    # Redact basic PII patterns
    t = EMAIL_RE.sub("[EMAIL]", t)
    t = PHONE_RE.sub("[PHONE]", t)
    t = URL_RE.sub("[URL]", t)
    t = IBAN_RE.sub("[IBAN]", t)

    # Collapse weird control chars
    t = t.replace("\x00", " ")
    return t.strip()

# =========================
# FILE DISCOVERY
# =========================
MSG_EXT = {".msg"}
PDF_EXT = {".pdf"}
IMG_EXT = {".png", ".jpg", ".jpeg", ".tif", ".tiff", ".bmp", ".gif", ".webp"}

def find_files(root_dirs: List[str], exts: set[str], cap: int) -> List[Path]:
    out: List[Path] = []
    for d in root_dirs:
        base = Path(d)
        if not base.exists():
            continue
        for p in base.rglob("*"):
            if p.is_file() and p.suffix.lower() in exts:
                out.append(p)
                if len(out) >= cap:
                    return out
    out.sort(key=lambda x: (x.name.lower(), str(x.parent).lower()))
    return out

# =========================
# PARSERS
# =========================
def read_msg_extract(p: Path) -> Tuple[bool, str]:
    """
    Uses extract-msg if installed.
    Returns (ok, text).
    """
    try:
        import extract_msg  # type: ignore
    except Exception as e:
        return (False, f"[MSG PARSE SKIP] extract_msg missing: {repr(e)}")

    try:
        m = extract_msg.Message(str(p))
        subj = clean_ws(getattr(m, "subject", "") or "")
        body = getattr(m, "body", None) or ""

        if not body:
            # try htmlBody (strip tags)
            hb = getattr(m, "htmlBody", None) or ""
            hb = re.sub(r"<[^>]+>", " ", hb, flags=re.S)
            body = hb

        body = (body or "").replace("\r\n", "\n")
        body = body.strip()

        # include minimal header
        parts = []
        if subj:
            parts.append(f"Subject: {subj}")
        if body:
            parts.append(body)

        txt = "\n\n".join(parts).strip()
        txt = txt[:MAX_CHARS_PER_ITEM]
        return (True, txt)
    except Exception as e:
        return (False, f"[MSG PARSE FAIL] {p.name}: {repr(e)}")

HEADER_SPLIT_RE = re.compile(
    r"(?im)^\s*(from|von|sent|gesendet|to|an|cc|bcc|subject|betreff)\s*:\s*.*$"
)

def reorder_oldest_first(thread_text: str) -> str:
    """
    Heuristic: split on common mail headers and reverse blocks so the oldest (bottom) comes first.
    If split fails, return original text.
    """
    if not thread_text:
        return ""

    # Normalize
    t = thread_text.replace("\r\n", "\n")

    # Split into blocks: whenever header lines appear, start a new block
    lines = t.splitlines()
    blocks: List[List[str]] = []
    cur: List[str] = []

    for ln in lines:
        if HEADER_SPLIT_RE.match(ln) and cur:
            blocks.append(cur)
            cur = [ln]
        else:
            cur.append(ln)
    if cur:
        blocks.append(cur)

    # If we didn't really split, just return
    if len(blocks) <= 1:
        return t.strip()

    # Reverse blocks: oldest first (bottom-most) assumed last block
    blocks = list(reversed(blocks))
    out = "\n".join("\n".join(b).strip() for b in blocks if "\n".join(b).strip())
    return out.strip()

def read_pdf_text(p: Path) -> Tuple[bool, str]:
    # try pdfplumber, fallback pypdf
    try:
        import pdfplumber  # type: ignore
        out = []
        with pdfplumber.open(str(p)) as pdf:
            for page in pdf.pages[:40]:
                out.append(page.extract_text() or "")
        txt = "\n".join(out).strip()
        return (True, txt[:MAX_CHARS_PER_ITEM])
    except Exception:
        pass

    try:
        from pypdf import PdfReader  # type: ignore
        r = PdfReader(str(p))
        out = []
        for pg in r.pages[:40]:
            out.append((pg.extract_text() or ""))
        txt = "\n".join(out).strip()
        return (True, txt[:MAX_CHARS_PER_ITEM])
    except Exception as e:
        return (False, f"[PDF PARSE FAIL] {p.name}: {repr(e)}")

def read_image_ocr(p: Path) -> Tuple[bool, str]:
    if not LOCAL_OCR_IMAGES:
        return (False, "[IMG SKIP] LOCAL_OCR_IMAGES=False")

    try:
        from PIL import Image  # type: ignore
        import pytesseract  # type: ignore
    except Exception as e:
        return (False, f"[IMG OCR SKIP] deps missing: {repr(e)}")

    try:
        txt = pytesseract.image_to_string(Image.open(str(p)), lang="eng")
        txt = clean_ws(txt)
        return (True, txt[:MAX_CHARS_PER_ITEM])
    except Exception as e:
        return (False, f"[IMG OCR FAIL] {p.name}: {repr(e)}")

# =========================
# LLM
# =========================
def build_client() -> AzureOpenAI:
    k = os.getenv("OPENAI_API_KEY", "").strip()
    if not k:
        raise RuntimeError("OPENAI_API_KEY missing in environment")
    return AzureOpenAI(api_key=k, azure_endpoint=AZURE_OPENAI_ENDPOINT, api_version=AZURE_API_VERSION)

def llm_summarize(client: AzureOpenAI, prompt: str, max_completion_tokens: int) -> str:
    """
    Returns "" if filtered/empty instead of crashing.
    """
    try:
        resp = client.chat.completions.create(
            model=AZURE_DEPLOYMENT_NAME,
            temperature=0.1,
            max_completion_tokens=max_completion_tokens,
            messages=[
                {"role": "system", "content": "You summarize corporate email discussions. Do not output personal data."},
                {"role": "user", "content": prompt},
            ],
        )
        out = resp.choices[0].message.content or ""
        return out.strip()
    except Exception as e:
        # Catch Azure content_filter and other 4xx
        return ""

def chunk_text(text: str, chunk_size: int) -> List[str]:
    if not text:
        return []
    chunks = []
    for i in range(0, len(text), chunk_size):
        chunks.append(text[i:i+chunk_size])
    return chunks

def summarize_chunk(client: AzureOpenAI, chunk: str, idx: int, total: int) -> str:
    safe = sanitize_for_llm(chunk)

    # Primary prompt (short + low risk)
    prompt = (
        "Summarize IMPORTANT content from these email conversations.\n"
        "Ignore greetings, thanks, forwarding, scheduling, and delegation.\n"
        "Extract only:\n"
        "- key questions (buyers/suppliers)\n"
        "- the answers/decisions\n"
        "- requirements, deadlines, platforms, templates\n"
        "- open points / follow-ups\n"
        "Return bullet points. Keep it factual. Do not include any personal data.\n\n"
        f"CHUNK {idx}/{total}:\n{safe}"
    )
    s = llm_summarize(client, prompt, max_completion_tokens=700)
    if s:
        return s

    # Retry with smaller chunk and even simpler prompt
    safe2 = safe[:CHUNK_SIZE_RETRY]
    prompt2 = (
        "Extract the key requirements + answers from the text below.\n"
        "Bullets only. No personal data.\n\n"
        f"CHUNK {idx}/{total} (retry):\n{safe2}"
    )
    s2 = llm_summarize(client, prompt2, max_completion_tokens=600)
    return s2.strip()

def map_reduce_summary(client: AzureOpenAI, full_text: str) -> str:
    safe_full = sanitize_for_llm(full_text)[:MAX_COMBINED_CHARS]
    chunks = chunk_text(safe_full, CHUNK_SIZE)

    print(f"Chunks: {len(chunks)} | first chunk chars: {len(chunks[0]) if chunks else 0}")

    partials = []
    for idx, ch in enumerate(chunks, start=1):
        s = summarize_chunk(client, ch, idx, len(chunks))
        print(f"chunk {idx}/{len(chunks)} -> summary chars:", len(s))
        if s:
            partials.append(s)

    if not partials:
        raise RuntimeError("All map summaries returned empty (likely content filter).")

    combined = "\n\n".join(partials).strip()

    final_prompt = (
        f"Combine these partial summaries into ONE coherent summary under {MAX_FINAL_WORDS} words.\n"
        "Structure:\n"
        "- Major themes\n"
        "- Repeated buyer/supplier questions\n"
        "- Our standard answers/positions\n"
        "- Requirements & deadlines\n"
        "- Open points\n"
        "Use bullet points where helpful. Do not include personal data.\n\n"
        f"{combined}"
    )
    final = llm_summarize(client, final_prompt, max_completion_tokens=1200).strip()
    if not final:
        raise RuntimeError("Final reduce step returned empty.")
    return final

# =========================
# OUTPUT WRITERS
# =========================
def write_docx(text: str, out_path: Path):
    from docx import Document  # type: ignore
    doc = Document()
    for para in (text or "").split("\n"):
        doc.add_paragraph(para)
    doc.save(str(out_path))

def write_html(text: str, out_path: Path):
    # simple html with <pre>
    html = "<html><head><meta charset='utf-8'></head><body>"
    html += "<pre style='white-space:pre-wrap;font-family:Segoe UI, Arial; font-size:12pt;'>"
    html += (text or "").replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")
    html += "</pre></body></html>"
    out_path.write_text(html, encoding="utf-8")

def write_pdf(text: str, out_path: Path):
    try:
        from reportlab.lib.pagesizes import A4  # type: ignore
        from reportlab.pdfgen import canvas  # type: ignore
    except Exception:
        print("PDF skipped: reportlab not installed.")
        return

    c = canvas.Canvas(str(out_path), pagesize=A4)
    width, height = A4
    x = 40
    y = height - 50
    line_h = 14

    for line in (text or "").splitlines():
        if y < 60:
            c.showPage()
            y = height - 50
        c.drawString(x, y, line[:140])  # simple cut
        y -= line_h

    c.save()

# =========================
# MAIN RUNNER
# =========================
def run_summary():
    print("OPENAI_API_KEY present:", bool(os.getenv("OPENAI_API_KEY")), "len:", len(os.getenv("OPENAI_API_KEY","")))

    msg_files = find_files(MAIL_DIRS, MSG_EXT, cap=MAX_MSG_FILES)
    pdf_files = find_files(MAIL_DIRS, PDF_EXT, cap=MAX_PDF_FILES)
    img_files = find_files(MAIL_DIRS, IMG_EXT, cap=MAX_IMG_FILES)

    print("Found .msg:", len(msg_files))
    print("Found loose PDFs:", len(pdf_files))
    print("Found loose images:", len(img_files))
    print("Local OCR images:", LOCAL_OCR_IMAGES)

    failures = []
    parsed_ok = 0

    items_text = []

    # Parse MSG
    for p in msg_files:
        ok, txt = read_msg_extract(p)
        if ok:
            parsed_ok += 1
            txt = reorder_oldest_first(txt)
            txt = txt[:MAX_CHARS_PER_ITEM]
            items_text.append(f"\n\n=== MSG: {p.name} ===\n{txt}\n")
        else:
            failures.append(txt)

    # Parse PDFs (loose)
    for p in pdf_files:
        ok, txt = read_pdf_text(p)
        if ok and txt.strip():
            items_text.append(f"\n\n=== PDF: {p.name} ===\n{txt}\n")
        elif not ok:
            failures.append(txt)

    # Parse Images (loose) if enabled
    if LOCAL_OCR_IMAGES:
        for p in img_files:
            ok, txt = read_image_ocr(p)
            if ok and txt.strip():
                items_text.append(f"\n\n=== IMG(OCR): {p.name} ===\n{txt}\n")
            elif not ok and "SKIP" not in txt:
                failures.append(txt)

    combined = "\n".join(items_text)
    combined = combined[:MAX_COMBINED_CHARS]

    print("\nParsed OK:", parsed_ok, "| Failed:", len(failures))
    print("Combined chars:", len(combined))

    ts = now_stamp()
    failures_log = OUT_DIR / f"parse_failures_{ts}.txt"
    failures_log.write_text("\n".join(failures) if failures else "(none)", encoding="utf-8")

    client = build_client()
    summary = map_reduce_summary(client, combined)

    out_docx = OUT_DIR / f"mail_conversations_summary_{ts}.docx"
    out_html = OUT_DIR / f"mail_conversations_summary_{ts}.html"
    out_pdf  = OUT_DIR / f"mail_conversations_summary_{ts}.pdf"
    out_json = OUT_DIR / f"mail_conversations_summary_{ts}.json"

    write_docx(summary, out_docx)
    write_html(summary, out_html)
    write_pdf(summary, out_pdf)

    stats = {
        "timestamp": datetime.now().isoformat(timespec="seconds"),
        "folders": MAIL_DIRS,
        "msg_found": len(msg_files),
        "msg_parsed_ok": parsed_ok,
        "msg_failed": len(failures),
        "loose_pdf_count": len(pdf_files),
        "loose_img_count": len(img_files),
        "local_ocr_images": LOCAL_OCR_IMAGES,
        "combined_chars": len(combined),
        "output_words_est": len(summary.split()),
        "files": {
            "docx": str(out_docx),
            "html": str(out_html),
            "pdf": str(out_pdf),
            "stats_json": str(out_json),
            "failures_log": str(failures_log),
        },
    }
    out_json.write_text(json.dumps(stats, ensure_ascii=False, indent=2), encoding="utf-8")

    print("\nDONE")
    print("DOCX:", out_docx)
    print("HTML:", out_html)
    print("PDF :", out_pdf)
    print("STATS:", out_json)
    print("FAIL :", failures_log)

    return summary, stats


# --- RUN (one-liner) ---
summary, stats = run_summary()
summary[:1200]  # preview
