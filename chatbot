def find_files(roots: List[str], exts: set[str]) -> List[Path]:
    out: List[Path] = []
    for r in roots:
        base = Path(r)
        if not base.exists():
            continue
        out.extend([p for p in base.rglob("*") if p.is_file() and p.suffix.lower() in exts])
    out.sort(key=lambda p: str(p).lower())
    return out

