import os, base64
from pathlib import Path
from openai import AzureOpenAI

AZURE_OPENAI_ENDPOINT = "https://genai-nexus.api.corpinter.net"
AZURE_API_VERSION = "2024-06-01"
VISION_DEPLOYMENT = "gpt-5.1"

client = AzureOpenAI(
    api_key=os.getenv("OPENAI_API_KEY"),
    azure_endpoint=AZURE_OPENAI_ENDPOINT,
    api_version=AZURE_API_VERSION,
)

IMG_DIR = Path(r"C:\Users\SHTANDO\OneDrive - Mercedes-Benz (corpdir.onmicrosoft.com)\DWT_MP_RM1 - Dokumente\Project Chatbot\Available data\Mails\_exports\collect_att_20260224_092225\images")

IMG_EXTS = {".png", ".jpg", ".jpeg", ".tif", ".tiff", ".bmp", ".gif", ".webp"}

# Pick the first image file
imgs = [p for p in IMG_DIR.rglob("*") if p.is_file() and p.suffix.lower() in IMG_EXTS]
if not imgs:
    raise SystemExit(f"No images found under: {IMG_DIR}")

img_path = imgs[0]
print("Using image:", img_path)

def b64_data_url(path: Path) -> str:
    ext = path.suffix.lower()
    mime = "image/png" if ext == ".png" else "image/jpeg" if ext in {".jpg", ".jpeg"} else "image/png"
    data = path.read_bytes()
    return f"data:{mime};base64," + base64.b64encode(data).decode("utf-8")

resp = client.chat.completions.create(
    model=VISION_DEPLOYMENT,
    temperature=0.0,
    max_completion_tokens=80,
    messages=[
        {"role": "system", "content": "Reply with exactly OK."},
        {"role": "user", "content": [
            {"type": "text", "text": "ping"},
            {"type": "image_url", "image_url": {"url": b64_data_url(img_path)}},
        ]},
    ],
)

print("Model says:", resp.choices[0].message.content)
