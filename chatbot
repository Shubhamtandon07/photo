def write_docx(text: str, out_path: Path):
    from docx import Document  # type: ignore
    doc = Document()
    doc.add_heading("Mail Conversations Summary", level=1)
    for para in (text or "").split("\n"):
        if para.strip().startswith("- "):
            doc.add_paragraph(para.strip()[2:], style="List Bullet")
        elif para.strip():
            doc.add_paragraph(para.strip())
        else:
            doc.add_paragraph("")
    doc.save(str(out_path))

def write_html(text: str, out_path: Path):
    lines = (text or "").split("\n")
    html = ["<html><head><meta charset='utf-8'></head><body>"]
    html.append("<h1>Mail Conversations Summary</h1>")
    in_ul = False
    for ln in lines:
        s = ln.strip()
        if s.startswith("- "):
            if not in_ul:
                html.append("<ul>")
                in_ul = True
            html.append("<li>" + s[2:].replace("&","&amp;").replace("<","&lt;").replace(">","&gt;") + "</li>")
        else:
            if in_ul:
                html.append("</ul>")
                in_ul = False
            if s:
                html.append("<p>" + s.replace("&","&amp;").replace("<","&lt;").replace(">","&gt;") + "</p>")
            else:
                html.append("<br>")
    if in_ul:
        html.append("</ul>")
    html.append("</body></html>")
    out_path.write_text("\n".join(html), encoding="utf-8")

def write_pdf(text: str, out_path: Path) -> bool:
    try:
        from reportlab.lib.pagesizes import A4  # type: ignore
        from reportlab.pdfgen import canvas  # type: ignore
    except Exception:
        return False

    c = canvas.Canvas(str(out_path), pagesize=A4)
    width, height = A4
    x, y = 50, height - 60
    c.setFont("Helvetica-Bold", 14)
    c.drawString(x, y, "Mail Conversations Summary")
    y -= 30
    c.setFont("Helvetica", 10)

    for ln in (text or "").split("\n"):
        s = ln.strip()
        if not s:
            y -= 10
        else:
            # wrap crudely
            while len(s) > 110:
                c.drawString(x, y, s[:110])
                s = s[110:]
                y -= 12
                if y < 60:
                    c.showPage()
                    y = height - 60
                    c.setFont("Helvetica", 10)
            c.drawString(x, y, s)
            y -= 12
        if y < 60:
            c.showPage()
            y = height - 60
            c.setFont("Helvetica", 10)

    c.save()
    return True

