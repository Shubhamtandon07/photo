# MAIN
# =========================
def run_summary():
    OUT_DIR.mkdir(parents=True, exist_ok=True)

    # basic env check
    k = os.getenv("OPENAI_API_KEY", "")
    print("OPENAI_API_KEY present:", bool(k), "len:", len(k))

    msg_files = find_files(MAIL_DIRS, MSG_EXT)
    pdf_files = find_files(MAIL_DIRS, PDF_EXT)
    img_files = find_files(MAIL_DIRS, IMG_EXT)

    if MAX_MSG_FILES is not None:
        msg_files = msg_files[:MAX_MSG_FILES]
    if MAX_PDF_FILES is not None:
        pdf_files = pdf_files[:MAX_PDF_FILES]
    if MAX_IMG_FILES is not None:
        img_files = img_files[:MAX_IMG_FILES]

    print("Found .msg:", len(msg_files))
    print("Found loose PDFs:", len(pdf_files))
    print("Found loose images:", len(img_files))
    print("Vision enabled:", VISION_ENABLED)

    # parse .msg
    parsed_ok = 0
    failed = 0
    texts: List[str] = []
    failures: List[str] = []

    for p in msg_files:
        ok, t = parse_msg(p)
        if ok and t.strip():
            parsed_ok += 1
            texts.append(f"\n\n=== MSG FILE: {p.name} ===\n{t}\n")
        else:
            failed += 1
            failures.append(str(p))

    print("Parsed OK:", parsed_ok, "| Failed:", failed)

    # parse loose PDFs (text only)
    pdf_ok = 0
    for p in pdf_files:
        ok, t = parse_pdf(p)
        if ok and t.strip():
            pdf_ok += 1
            texts.append(f"\n\n=== PDF FILE: {p.name} ===\n{t}\n")

    # parse images (optional vision)
    img_ok = 0
    client = build_client()
    if VISION_ENABLED and VISION_DEPLOYMENT:
        for p in img_files:
            ok, t = parse_image_with_vision(client, p)
            if ok and t.strip():
                img_ok += 1
                texts.append(f"\n\n=== IMAGE FILE: {p.name} ===\n{t}\n")

    combined_text = "\n".join(texts)
    combined_text = combined_text[:MAX_INPUT_CHARS_TOTAL]
    print("Combined chars:", len(combined_text))

    # write failures log
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    failures_log = OUT_DIR / f"parse_failures_{ts}.txt"
    if failures:
        failures_log.write_text("\n".join(failures), encoding="utf-8")

    # summarization
    summary = map_reduce_summary(client, combined_text)

    # write outputs
    out_docx = OUT_DIR / f"mail_conversations_summary_{ts}.docx"
    out_html = OUT_DIR / f"mail_conversations_summary_{ts}.html"
    out_pdf  = OUT_DIR / f"mail_conversations_summary_{ts}.pdf"
    out_md   = OUT_DIR / f"mail_conversations_summary_{ts}.md"
    out_stats = OUT_DIR / f"mail_conversations_summary_{ts}.json"

    out_md.write_text(summary, encoding="utf-8")
    write_html(summary, out_html)
    write_docx(summary, out_docx)
    pdf_ok_written = write_pdf(summary, out_pdf)

    stats = {
        "timestamp": datetime.now().isoformat(timespec="seconds"),
        "folders": MAIL_DIRS,
        "msg_found": len(msg_files),
        "msg_parsed_ok": parsed_ok,
        "msg_failed": failed,
        "pdf_found": len(pdf_files),
        "pdf_parsed_ok": pdf_ok,
        "img_found": len(img_files),
        "img_parsed_ok": img_ok,
        "vision_enabled": bool(VISION_ENABLED and VISION_DEPLOYMENT),
        "combined_chars": len(combined_text),
        "output_words_est": len(summary.split()),
        "files": {
            "md": str(out_md),
            "html": str(out_html),
            "docx": str(out_docx),
            "pdf": str(out_pdf) if pdf_ok_written else None,
            "stats_json": str(out_stats),
            "failures_log": str(failures_log) if failures else None,
        }
    }
    out_stats.write_text(json.dumps(stats, ensure_ascii=False, indent=2), encoding="utf-8")

    print("\nDONE")
    print("DOCX:", out_docx)
    print("HTML:", out_html)
    print("PDF :", out_pdf if pdf_ok_written else "(skipped — reportlab missing)")
    print("MD  :", out_md)
    print("Stats:", out_stats)
    if failures:
        print("Failures log:", failures_log)

    return summary, stats

