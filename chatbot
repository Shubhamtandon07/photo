# =========================
# SAFETY: PII REDACTION + INJECTION SANITIZE
# =========================
EMAIL_RE = re.compile(r"\b[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}\b", re.I)
PHONE_RE = re.compile(r"(?:(?:\+|00)\d{1,3}[\s\-]?)?(?:\(?\d{2,5}\)?[\s\-]?)?\d[\d\s\-]{6,}\d")
URL_RE = re.compile(r"\bhttps?://[^\s<>()]+\b", re.I)
IBAN_RE = re.compile(r"\b[A-Z]{2}\d{2}[A-Z0-9]{11,30}\b", re.I)
REF_RE = re.compile(r"\b(?:VU|SP|PR|PO|NCR|Ticket|Case|Req|Request|ID|Ref)\s*[:#]?\s*[A-Za-z0-9\-_/]*\d[A-Za-z0-9\-_/]*\b", re.I)

JAILBREAK_PATTERNS = [
    r"(?i)\bignore (all|any|previous) instructions\b",
    r"(?i)\bdisregard (all|any|previous) instructions\b",
    r"(?i)\byou are (now )?(chatgpt|an ai|a language model)\b",
    r"(?i)\b(system prompt|developer message|hidden prompt)\b",
    r"(?i)\bact as\b",
    r"(?i)\bjailbreak\b",
    r"(?i)\bdo anything now\b",
    r"(?i)\bDAN\b",
    r"(?i)\brole\s*:\s*(system|developer)\b",
]
JAILBREAK_RE = re.compile("|".join(JAILBREAK_PATTERNS))

def clean_ws(s: str) -> str:
    return re.sub(r"\s+", " ", s or "").strip()

def sanitize_for_policy(text: str) -> str:
    if not text:
        return ""
    t = text
    t = JAILBREAK_RE.sub("[REMOVED_INJECTION_TEXT]", t)
    t = re.sub(r"[<>{}\[\]]{3,}", " ", t)
    t = re.sub(r"\s+", " ", t).strip()
    return t

def redact_pii(text: str) -> str:
    if not text:
        return ""
    t = text
    t = EMAIL_RE.sub("[EMAIL]", t)
    t = PHONE_RE.sub("[PHONE]", t)
    t = URL_RE.sub("[URL]", t)
    t = IBAN_RE.sub("[IBAN]", t)
    t = REF_RE.sub("[REF]", t)
    t = re.sub(r"\s+", " ", t).strip()
    return t

def safe_for_llm(text: str) -> str:
    return redact_pii(sanitize_for_policy(text))

