from pathlib import Path

roots = [
    r"C:\Program Files",
    r"C:\Program Files (x86)",
    r"C:\Users",
    r"C:\ProgramData",
    r"C:\Windows",
]

hits = []
for r in roots:
    base = Path(r)
    if not base.exists():
        continue
    try:
        # search only 5 levels deep to avoid insane runtime
        for p in base.rglob("tesseract.exe"):
            hits.append(str(p))
            if len(hits) >= 30:
                break
    except Exception as e:
        print("skip", r, "->", repr(e))
    if len(hits) >= 30:
        break

print("Hits:", hits[:30])
print("Total hits found (capped):", len(hits))
