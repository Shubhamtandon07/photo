def parse_msg(path: Path) -> Tuple[bool, str]:
    """
    Returns (ok, text). Requires extract-msg. If missing, returns (False,"").
    """
    try:
        import extract_msg  # type: ignore
    except Exception:
        return False, ""
    try:
        m = extract_msg.Message(str(path))
        subj = clean_ws(getattr(m, "subject", "") or "")
        body = getattr(m, "body", None) or ""
        if not body:
            body = getattr(m, "htmlBody", None) or ""
            body = re.sub(r"<[^>]+>", " ", body, flags=re.S)
        body = clean_ws(body)

        # Keep structure: bottom-most message is often at the end in exports,
        # but we can't reliably reorder. We'll preserve body as-is and let LLM focus on "Q/A + decisions".
        parts = []
        if subj:
            parts.append(f"SUBJECT: {subj}")
        if body:
            parts.append(body)

        return True, "\n".join(parts).strip()
    except Exception:
        return False, ""

def parse_pdf(path: Path) -> Tuple[bool, str]:
    # prefer pdfplumber
    try:
        import pdfplumber  # type: ignore
        out = []
        with pdfplumber.open(str(path)) as pdf:
            for pg in pdf.pages[:50]:
                out.append(pg.extract_text() or "")
        txt = "\n".join(out).strip()
        return (bool(txt.strip()), txt)
    except Exception:
        pass
    # fallback pypdf
    try:
        from pypdf import PdfReader  # type: ignore
        r = PdfReader(str(path))
        out = []
        for pg in r.pages[:50]:
            try:
                out.append(pg.extract_text() or "")
            except Exception:
                pass
        txt = "\n".join(out).strip()
        return (bool(txt.strip()), txt)
    except Exception:
        return False, ""

def parse_image_with_vision(client: AzureOpenAI, path: Path) -> Tuple[bool, str]:
    """
    Optional: If you have a vision deployment. Otherwise keep VISION_ENABLED=False.
    """
    if not (VISION_ENABLED and VISION_DEPLOYMENT):
        return False, ""
    import base64
    b = base64.b64encode(path.read_bytes()).decode("utf-8")
    mime = "image/png" if path.suffix.lower() == ".png" else "image/jpeg"
    data_url = f"data:{mime};base64,{b}"

    resp = client.chat.completions.create(
        model=VISION_DEPLOYMENT,
        temperature=0.0,
        max_completion_tokens=200,
        messages=[
            {"role": "system", "content": "Extract only business-relevant text from the image. No personal data."},
            {"role": "user", "content": [
                {"type": "text", "text": "Extract the visible text (and only key business statements)."},
                {"type": "image_url", "image_url": {"url": data_url}},
            ]},
        ],
    )
    txt = (resp.choices[0].message.content or "").strip()
    return (bool(txt), txt)

